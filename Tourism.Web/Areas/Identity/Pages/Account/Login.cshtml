@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-logo">
            <a href="/" style="text-decoration:none">
                <span style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--viator-green)">NaviGo</span>
            </a>
        </div>

        <h1 class="auth-title">Добре дошъл!</h1>
        <p class="auth-sub">Влез в акаунта си, за да резервираш </p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label">Имейл</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username"
                       aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label">Парола</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="current-password"
                       aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>

            <div class="auth-remember">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.875rem">
                    <input class="form-check-input" asp-for="Input.RememberMe" style="accent-color:var(--viator-green)" />
                    Запомни ме
                </label>
                <a asp-page="./ForgotPassword" class="auth-link">Забравена парола?</a>
            </div>

            <button id="login-submit" type="submit" class="btn-viator auth-btn">Влез</button>
        </form>

        <div class="auth-divider"><span>Нямаш акаунт?</span></div>

        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn-viator-outline auth-btn">
            Регистрирай се безплатно
        </a>

        <div style="text-align:center;margin-top:16px">
            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="auth-link" style="font-size:0.8rem">
                Препрати имейл за потвърждение
            </a>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 64px);
        background: var(--viator-light);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }

    .auth-card {
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 16px;
        padding: 40px;
        width: 100%;
        max-width: 440px;
        box-shadow: var(--shadow-md);
    }

    .auth-logo {
        text-align: center;
        margin-bottom: 24px;
    }

    .auth-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.6rem;
        text-align: center;
        margin-bottom: 6px;
    }

    .auth-sub {
        color: var(--viator-gray);
        text-align: center;
        font-size: 0.9rem;
        margin-bottom: 28px;
    }

    .auth-error {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        padding: 12px 16px;
        color: #DC2626;
        font-size: 0.875rem;
        margin-bottom: 16px;
    }

    .auth-field {
        margin-bottom: 16px;
    }

    .auth-label {
        display: block;
        font-weight: 600;
        font-size: 0.82rem;
        margin-bottom: 6px;
        color: var(--viator-dark);
    }

    .auth-input {
        width: 100%;
        border: 1.5px solid var(--viator-border);
        border-radius: 8px;
        padding: 11px 14px;
        font-size: 0.9rem;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.15s;
    }

        .auth-input:focus {
            border-color: var(--viator-green);
            box-shadow: 0 0 0 3px rgba(0,170,108,0.12);
        }

    .auth-validation {
        color: #ef4444;
        font-size: 0.78rem;
        margin-top: 4px;
        display: block;
    }

    .auth-remember {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .auth-link {
        color: var(--viator-green);
        text-decoration: none;
        font-size: 0.875rem;
    }

        .auth-link:hover {
            text-decoration: underline;
        }

    .auth-btn {
        display: block;
        width: 100%;
        text-align: center;
        padding: 13px !important;
        font-size: 0.95rem !important;
        border-radius: 8px !important;
    }

    .auth-divider {
        text-align: center;
        margin: 20px 0 12px;
        position: relative;
        color: var(--viator-gray);
        font-size: 0.82rem;
    }

        .auth-divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: var(--viator-border);
        }

        .auth-divider span {
            background: #fff;
            padding: 0 12px;
            position: relative;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
