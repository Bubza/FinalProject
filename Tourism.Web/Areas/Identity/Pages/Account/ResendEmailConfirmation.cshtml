@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend Confirmation";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <span style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--viator-green)">NaviGo</span>
        </div>
        <h1 class="auth-title">Resend Confirmation</h1>
        <p class="auth-sub">Enter your email and we'll send you a new confirmation link</p>

        <form method="post">
            <div asp-validation-summary="All" class="auth-error" role="alert"></div>
            <div class="auth-field">
                <label class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>
            <button type="submit" class="btn-viator auth-btn">Resend</button>
        </form>

        <div style="text-align:center;margin-top:20px">
            <a asp-page="./Login" class="auth-link">Back to Sign In</a>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 64px);
        background: var(--viator-light);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }

    .auth-card {
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 16px;
        padding: 40px;
        width: 100%;
        max-width: 440px;
        box-shadow: var(--shadow-md);
    }

    .auth-logo {
        text-align: center;
        margin-bottom: 24px;
    }

    .auth-title {
        font-family: 'DM Serif Display',serif;
        font-size: 1.6rem;
        text-align: center;
        margin-bottom: 6px;
    }

    .auth-sub {
        color: var(--viator-gray);
        text-align: center;
        font-size: 0.9rem;
        margin-bottom: 28px;
    }

    .auth-error {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        padding: 12px 16px;
        color: #DC2626;
        font-size: 0.875rem;
        margin-bottom: 16px;
    }

    .auth-field {
        margin-bottom: 16px;
    }

    .auth-label {
        display: block;
        font-weight: 600;
        font-size: 0.82rem;
        margin-bottom: 6px;
    }

    .auth-input {
        width: 100%;
        border: 1.5px solid var(--viator-border);
        border-radius: 8px;
        padding: 11px 14px;
        font-size: 0.9rem;
        font-family: 'DM Sans',sans-serif;
        outline: none;
        transition: border-color 0.15s;
    }

        .auth-input:focus {
            border-color: var(--viator-green);
            box-shadow: 0 0 0 3px rgba(0,170,108,0.12);
        }

    .auth-validation {
        color: #ef4444;
        font-size: 0.78rem;
        margin-top: 4px;
        display: block;
    }

    .auth-btn {
        display: block;
        width: 100%;
        text-align: center;
        padding: 13px !important;
        font-size: 0.95rem !important;
        border-radius: 8px !important;
    }

    .auth-link {
        color: var(--viator-green);
        text-decoration: none;
        font-size: 0.875rem;
    }

        .auth-link:hover {
            text-decoration: underline;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}