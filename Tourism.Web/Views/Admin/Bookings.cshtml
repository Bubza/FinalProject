@model IEnumerable<Tourism.Data.Models.Entities.Booking>
@{
    ViewData["Title"] = "Manage Bookings";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <h1 class="mb-4">Manage Bookings</h1>

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>User</th>
                <th>Tour</th>
                <th>Destination</th>
                <th>People</th>
                <th>Total Price</th>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.UserId.Substring(0, 8)...</td>
                    <td>@booking.Tour?.Title</td>
                    <td>@booking.Tour?.Destination?.Name</td>
                    <td>@booking.NumberOfPeople</td>
                    <td>@booking.TotalPrice.ToString("C")</td>
                    <td>@booking.BookedAt.ToString("dd.MM.yyyy")</td>
                    <td>
                        @{
                            var badgeClass = booking.Status switch
                            {
                                Tourism.Data.Models.Enums.BookingStatus.Confirmed => "badge bg-success",
                                Tourism.Data.Models.Enums.BookingStatus.Cancelled => "badge bg-danger",
                                Tourism.Data.Models.Enums.BookingStatus.Completed => "badge bg-secondary",
                                _ => "badge bg-warning text-dark"
                            };
                            var statusText = booking.Status switch
                            {
                                Tourism.Data.Models.Enums.BookingStatus.Confirmed => "Confirmed",
                                Tourism.Data.Models.Enums.BookingStatus.Cancelled => "Cancelled",
                                Tourism.Data.Models.Enums.BookingStatus.Completed => "Completed",
                                _ => "Pending"
                            };
                        }
                        <span class="@badgeClass">@statusText</span>
                    </td>
                    <td>
                        @if (booking.Status == Tourism.Data.Models.Enums.BookingStatus.Pending)
                        {
                            <form asp-action="ConfirmBooking" asp-route-id="@booking.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                            </form>
                            <form asp-action="CancelBooking" asp-route-id="@booking.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>