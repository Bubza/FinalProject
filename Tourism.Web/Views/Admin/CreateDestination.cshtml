@model Tourism.Data.Models.Entities.Destination
@{
    ViewData["Title"] = "New Destination";
}

<div class="container my-4">
    <h1 class="mb-4">New Destination</h1>

    <div class="card shadow-sm p-4">
        <form asp-action="CreateDestination" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Country" class="form-label">Country</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Add Destination</button>
            <a asp-action="Destinations" class="btn btn-outline-secondary ms-2">Back</a>
        </form>
    </div>
</div>