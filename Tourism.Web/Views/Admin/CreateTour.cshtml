@model Tourism.Web.Models.Entities.Tour
@{
    ViewData["Title"] = "Нов маршрут";
}

<div class="container my-4">
    <h1 class="mb-4">Нов маршрут</h1>

    <div class="card shadow-sm p-4">
        <form asp-action="CreateTour" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Заглавие</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="PricePerPerson" class="form-label">Цена на човек</label>
                    <input asp-for="PricePerPerson" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="DurationDays" class="form-label">Продължителност (дни)</label>
                    <input asp-for="DurationDays" class="form-control" type="number" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="MaxParticipants" class="form-label">Макс. участници</label>
                    <input asp-for="MaxParticipants" class="form-control" type="number" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label">Начална дата</label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label">Крайна дата</label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">URL на снимка</label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DestinationId" class="form-label">Дестинация</label>
                    <select asp-for="DestinationId" asp-items="ViewBag.Destinations" class="form-select">
                        <option value="">-- Избери --</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TourOperatorId" class="form-label">Туроператор</label>
                    <select asp-for="TourOperatorId" asp-items="ViewBag.TourOperators" class="form-select">
                        <option value="">-- Избери --</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Добави маршрут</button>
            <a asp-action="Tours" class="btn btn-outline-secondary ms-2">Назад</a>
        </form>
    </div>
</div>
