@model IEnumerable<Tourism.Web.Models.Entities.Destination>
@{
    ViewData["Title"] = "Управление на дестинации";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Управление на дестинации</h1>
        <a asp-action="CreateDestination" class="btn btn-primary">+ Нова дестинация</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Дестинация</th>
                <th>Държава</th>
                <th>Маршрути</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dest in Model)
            {
                <tr>
                    <td>@dest.Name</td>
                    <td>@dest.Country</td>
                    <td>@dest.Tours.Count</td>
                    <td>
                        <form asp-action="DeleteDestination" asp-route-id="@dest.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Сигурни ли сте?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Изтрий</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

