@model IEnumerable<Tourism.Data.Models.Entities.Destination>
@{
    ViewData["Title"] = "Manage Destinations";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Destinations</h1>
        <a asp-action="CreateDestination" class="btn btn-primary">+ New Destination</a>
    </div>

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Destination</th>
                <th>Country</th>
                <th>Tours</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dest in Model)
            {
                <tr>
                    <td>@dest.Name</td>
                    <td>@dest.Country</td>
                    <td>@dest.Tours.Count</td>
                    <td>
                        <form asp-action="DeleteDestination" asp-route-id="@dest.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>