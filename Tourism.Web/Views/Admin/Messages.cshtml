@model IEnumerable<Tourism.Data.Models.Entities.ContactMessage>
@{
    ViewData["Title"] = "Contact Messages";
    var unread = Model.Count(m => !m.IsRead);
    var messages = Model.ToList();
    var lookup = ViewBag.EmailToUserId as Dictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4 mt-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.8rem;">Contact Messages</h1>
            <p class="text-muted mb-0" style="font-size:.9rem;">
                Messages submitted through the contact form
                @if (unread > 0)
                {
                    <span class="badge rounded-pill ms-2" style="background:#FEF3C7;color:#92400E;">@unread unread</span>
                }
            </p>
        </div>
    </div>

    @if (!messages.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-envelope" style="font-size:2.5rem;"></i>
            <p class="mt-3">No messages yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Subject</th>
                        <th>Message</th>
                        <th>Sent</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < messages.Count; i++)
                    {
                        var msg = messages[i];
                        var userId = lookup.ContainsKey(msg.Email) ? lookup[msg.Email] : null;
                        <tr class="@(!msg.IsRead ? "table-warning" : "")">
                            <td>
                                @if (msg.IsRead)
                                {
                                    <span class="badge bg-light text-muted"><i class="bi bi-envelope-open"></i> Read</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#FEF3C7;color:#92400E;"><i class="bi bi-envelope-fill"></i> Unread</span>
                                }
                            </td>
                            <td>
                                @if (userId != null)
                                {
                                    <a href="/Users/Profile/@userId" class="fw-500 text-decoration-none" style="color:var(--viator-green);">
                                        @msg.Name
                                    </a>
                                }
                                else
                                {
                                    <span class="fw-500">@msg.Name</span>
                                }
                            </td>
                            <td class="text-muted small">@msg.Email</td>
                            <td class="fw-500">@msg.Subject</td>
                            <td>
                                <button class="btn btn-link p-0 text-muted small text-start"
                                        style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;"
                                        data-bs-toggle="modal" data-bs-target="#msgModal@(i)">
                                    @msg.Message
                                </button>
                            </td>
                            <td class="text-muted small">@msg.SentAt.ToString("dd MMM yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture)</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#msgModal@(i)" title="Read full message">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (!msg.IsRead)
                                    {
                                        <form asp-action="MarkMessageRead" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@msg.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Mark as read">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="DeleteMessage" method="post" style="display:inline"
                                          onsubmit="return confirm('Delete this message?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@msg.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        <!-- Modal -->
                        <div class="modal fade" id="msgModal@(i)" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">@msg.Subject</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="d-flex gap-3 mb-3">
                                            <div>
                                                <div style="font-size:.75rem;color:#6B7280;text-transform:uppercase;">From</div>
                                                <div class="fw-500">
                                                    @if (userId != null)
                                                    {
                                                        <a href="/Users/Profile/@userId" style="color:var(--viator-green);text-decoration:none;">@msg.Name</a>
                                                    }
                                                    else
                                                    {
                                                        @msg.Name
                                                    }
                                                </div>
                                                <div class="text-muted small">@msg.Email</div>
                                            </div>
                                            <div class="ms-auto text-end">
                                                <div style="font-size:.75rem;color:#6B7280;text-transform:uppercase;">Sent</div>
                                                <div class="small">@msg.SentAt.ToString("dd MMM yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture)</div>
                                            </div>
                                        </div>
                                        <hr />
                                        <p style="white-space:pre-wrap;line-height:1.7;">@msg.Message</p>
                                    </div>
                                    <div class="modal-footer">
                                        @if (!msg.IsRead)
                                        {
                                            <form asp-action="MarkMessageRead" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@msg.Id" />
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    <i class="bi bi-check-lg me-1"></i> Mark as Read
                                                </button>
                                            </form>
                                        }
                                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .fw-500 {
        font-weight: 500;
    }
</style>