@model IEnumerable<Tourism.Data.Models.Entities.ContactMessage>
@{
    ViewData["Title"] = "Contact Messages";
    var unread = Model.Count(m => !m.IsRead);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4 mt-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.8rem;">Contact Messages</h1>
            <p class="text-muted mb-0" style="font-size:.9rem;">
                Messages submitted through the contact form
                @if (unread > 0)
                {
                    <span class="badge rounded-pill ms-2" style="background:#FEF3C7;color:#92400E;">@unread unread</span>
                }
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-envelope" style="font-size:2.5rem;"></i>
            <p class="mt-3">No messages yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Subject</th>
                        <th>Message</th>
                        <th>Sent</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model)
                    {
                        <tr class="@(!msg.IsRead ? "table-warning" : "")">
                            <td>
                                @if (msg.IsRead)
                                {
                                    <span class="badge bg-light text-muted"><i class="bi bi-envelope-open"></i> Read</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#FEF3C7;color:#92400E;"><i class="bi bi-envelope-fill"></i> Unread</span>
                                }
                            </td>
                            <td class="fw-500">@msg.Name</td>
                            <td class="text-muted small">@msg.Email</td>
                            <td class="fw-500">@msg.Subject</td>
                            <td class="text-muted small" style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @msg.Message
                            </td>
                            <td class="text-muted small">@msg.SentAt.ToString("dd MMM yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture)</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    @if (!msg.IsRead)
                                    {
                                        <form asp-action="MarkMessageRead" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@msg.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Mark as read">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="DeleteMessage" method="post" style="display:inline"
                                          onsubmit="return confirm('Delete this message?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@msg.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .fw-500 {
        font-weight: 500;
    }
</style>