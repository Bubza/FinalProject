@model IEnumerable<Tourism.Data.Models.Entities.TourOperator>
@using Tourism.Data.Models.Entities
@{
    ViewData["Title"] = "Manage Operators";
    var allUsers = ViewBag.AllUsers as List<ApplicationUser> ?? new List<ApplicationUser>();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4 mt-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.8rem;">Manage Operators</h1>
            <p class="text-muted mb-0" style="font-size:.9rem;">Assign user accounts to tour operators</p>
        </div>
        <a asp-action="AssignOperator" class="btn btn-success">
            <i class="bi bi-person-plus me-1"></i> Assign Operator
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Tours</th>
                    <th>Linked Account</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var op in Model)
                {
                    var linkedUser = allUsers.FirstOrDefault(u => u.Id == op.UserId);
                    <tr>
                        <td class="fw-500">@op.Name</td>
                        <td class="text-muted small">@op.Email</td>
                        <td class="text-muted small">@op.PhoneNumber</td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark">@op.Tours?.Count() tours</span>
                        </td>
                        <td>
                            @if (linkedUser != null)
                            {
                                <span class="badge rounded-pill" style="background:#E6F7F1;color:#00AA6C;">
                                    <i class="bi bi-check-circle me-1"></i>@linkedUser.Email
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-light text-muted">
                                    <i class="bi bi-x-circle me-1"></i>Not assigned
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="DeleteOperator" method="post" style="display:inline"
                                  onsubmit="return confirm('Delete operator @op.Name? This cannot be undone.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@op.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .fw-500 {
        font-weight: 500;
    }
</style>