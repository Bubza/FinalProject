@model IEnumerable<Tourism.Data.Models.Entities.TourOperator>
@{
    ViewData["Title"] = "Manage Operators";
    var allUsers = ViewBag.AllUsers as List<Tourism.Data.Models.Entities.ApplicationUser> ?? new();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    .op-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .88rem;
    }

        .op-table th {
            font-weight: 700;
            padding: 10px 14px;
            border-bottom: 2px solid #E5E7EB;
            white-space: nowrap;
            background: #F9FAFB;
        }

        .op-table td {
            padding: 10px 14px;
            border-bottom: 1px solid #F3F4F6;
            vertical-align: middle;
        }

        .op-table tr:last-child td {
            border-bottom: none;
        }

    .badge-linked {
        background: #E0F2FE;
        color: #0369A1;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 600;
        white-space: nowrap;
        display: inline-block;
    }

    .badge-none {
        background: #FEE2E2;
        color: #DC2626;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 600;
        white-space: nowrap;
        display: inline-block;
    }

    .btn-assign-sm {
        background: #fff;
        border: 1.5px solid #00AA6C;
        color: #00AA6C;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
    }

        .btn-assign-sm:hover {
            background: #E6F7F1;
        }

    .btn-del-sm {
        background: #fff;
        border: 1.5px solid #DC2626;
        color: #DC2626;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-del-sm:hover {
            background: #FEE2E2;
        }
</style>

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="font-size:1.8rem;font-weight:800">Manage Tour Operators</h1>
        <div class="d-flex gap-2 align-items-center">
            <a asp-action="AssignOperator" class="btn-assign-sm" style="padding:8px 16px;font-size:.85rem">🔗 Assign Account</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Dashboard</a>
        </div>
    </div>

    <div style="border:1px solid #E5E7EB;border-radius:12px;overflow-x:auto">
        <table class="op-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Tours</th>
                    <th>Linked Account</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var op in Model)
                {
                    var linkedUser = allUsers.FirstOrDefault(u => u.Id == op.UserId);
                    var displayName = linkedUser == null ? null
                    : (!string.IsNullOrWhiteSpace(linkedUser.FullName) ? linkedUser.FullName : linkedUser.Email);
                    <tr>
                        <td>
                            <div style="font-weight:700">@op.Name</div>
                            <div style="font-size:.78rem;color:#6B7280">@op.Email</div>
                        </td>
                        <td style="color:#6B7280">@op.PhoneNumber</td>
                        <td>@op.Tours?.Count</td>
                        <td>
                            @if (linkedUser != null)
                            {
                                <span class="badge-linked">✅ @displayName</span>
                            }
                            else
                            {
                                <span class="badge-none">❌ No account</span>
                            }
                        </td>
                        <td>
                            <form asp-action="DeleteOperator" asp-route-id="@op.Id" method="post" style="display:inline"
                                  onsubmit="return confirm('Delete @op.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-del-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>