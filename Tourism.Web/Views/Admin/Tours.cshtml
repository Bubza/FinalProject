@model IEnumerable<Tourism.Web.Models.Entities.Tour>
@{
    ViewData["Title"] = "Управление на маршрути";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Управление на маршрути</h1>
        <a asp-action="CreateTour" class="btn btn-primary">+ Нов маршрут</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Заглавие</th>
                <th>Дестинация</th>
                <th>Оператор</th>
                <th>Цена</th>
                <th>Дата</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tour in Model)
            {
                <tr>
                    <td>@tour.Title</td>
                    <td>@tour.Destination?.Name</td>
                    <td>@tour.TourOperator?.Name</td>
                    <td>@tour.PricePerPerson.ToString("C")</td>
                    <td>@tour.StartDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="EditTour" asp-route-id="@tour.Id" class="btn btn-sm btn-outline-primary">Редактирай</a>
                        <form asp-action="DeleteTour" asp-route-id="@tour.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Сигурни ли сте?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Изтрий</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

