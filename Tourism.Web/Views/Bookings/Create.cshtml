@model Tourism.Web.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Резервация";
    int availableSpots = ViewBag.AvailableSpots ?? 0;
    bool lowAvailability = availableSpots <= 5;
}

<div style="background:var(--viator-light);border-bottom:1px solid var(--viator-border)">
    <div class="container">
        <ul class="breadcrumb-viator">
            <li><a asp-controller="Home" asp-action="Index">Начало</a></li>
            <li><a asp-controller="Tours" asp-action="Index">Маршрути</a></li>
            <li><a asp-controller="Tours" asp-action="Details" asp-route-id="@Model.TourId">@Model.TourTitle</a></li>
            <li class="active">Резервация</li>
        </ul>
    </div>
</div>

<div class="container" style="padding:40px 16px 80px;max-width:600px">

    <h1 style="font-family:'DM Serif Display',serif;font-size:1.8rem;margin-bottom:8px">Завърши резервацията</h1>
    <p style="color:var(--viator-gray);margin-bottom:32px">Провери детайлите и потвърди</p>

    <!-- Tour summary -->
    <div class="bk-summary">
        <div class="bk-summary-row">
            <span class="bk-label"><i class="bi bi-map"></i> Маршрут</span>
            <span class="bk-value">@Model.TourTitle</span>
        </div>
        <div class="bk-summary-row">
            <span class="bk-label"><i class="bi bi-geo-alt"></i> Дестинация</span>
            <span class="bk-value">@Model.DestinationName</span>
        </div>
        <div class="bk-summary-row">
            <span class="bk-label"><i class="bi bi-calendar-check"></i> Дата</span>
            <span class="bk-value">@Model.TourStartDate.ToString("dd MMMM yyyy")</span>
        </div>
        <div class="bk-summary-row">
            <span class="bk-label"><i class="bi bi-currency-euro"></i> Цена/човек</span>
            <span class="bk-value" style="font-weight:700">@Model.PricePerPerson.ToString("0.00") €</span>
        </div>
    </div>

    <!-- Availability badge -->
    @if (lowAvailability)
    {
        <div class="bk-urgency">
            <i class="bi bi-fire"></i>
            Само <strong>@availableSpots места</strong> останали — резервирай сега!
        </div>
    }
    else
    {
        <div class="bk-availability">
            <i class="bi bi-check-circle-fill"></i>
            @availableSpots свободни места
        </div>
    }

    <!-- Form -->
    <form asp-action="Create" method="post" style="margin-top:24px">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TourId" />
        <input type="hidden" asp-for="TourTitle" />
        <input type="hidden" asp-for="DestinationName" />
        <input type="hidden" asp-for="TourStartDate" />
        <input type="hidden" asp-for="PricePerPerson" />

        <div class="bk-field">
            <label class="bk-field-label">Брой хора</label>
            <div class="bk-counter">
                <button type="button" class="bk-counter-btn" onclick="changeCount(-1)">−</button>
                <input asp-for="NumberOfPeople" id="peopleInput" class="bk-counter-input"
                       type="number" min="1" max="@availableSpots" />
                <button type="button" class="bk-counter-btn" onclick="changeCount(1)">+</button>
            </div>
            <span asp-validation-for="NumberOfPeople" style="color:#ef4444;font-size:0.82rem"></span>
        </div>

        <!-- Price calculation -->
        <div class="bk-price-calc">
            <div class="bk-price-row">
                <span id="priceLabel">1 × @Model.PricePerPerson.ToString("0.00") €</span>
                <span id="totalDisplay">@Model.PricePerPerson.ToString("0.00") €</span>
            </div>
            <div class="bk-price-total">
                <span>Обща цена</span>
                <span id="totalBig">@Model.PricePerPerson.ToString("0.00") €</span>
            </div>
        </div>

        <button type="submit" class="btn-viator" style="width:100%;padding:15px;font-size:1rem;border-radius:10px;margin-top:8px">
            Потвърди резервацията
        </button>
        <a asp-controller="Tours" asp-action="Details" asp-route-id="@Model.TourId"
           class="btn-viator-outline" style="width:100%;text-align:center;margin-top:10px;padding:13px">
            Назад
        </a>
    </form>
</div>

<style>
    .bk-summary {
        background: var(--viator-light);
        border: 1px solid var(--viator-border);
        border-radius: var(--radius);
        padding: 4px 0;
        margin-bottom: 16px;
    }

    .bk-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border-bottom: 1px solid var(--viator-border);
        font-size: 0.9rem;
    }

        .bk-summary-row:last-child {
            border-bottom: none;
        }

    .bk-label {
        color: var(--viator-gray);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .bk-label i {
            color: var(--viator-green);
        }

    .bk-value {
        font-weight: 500;
    }

    .bk-urgency {
        background: #FFF7ED;
        border: 1px solid #FED7AA;
        border-radius: 8px;
        padding: 12px 16px;
        color: #C2410C;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .bk-availability {
        background: var(--viator-green-light);
        border: 1px solid #A7F3D0;
        border-radius: 8px;
        padding: 12px 16px;
        color: var(--viator-green-dark);
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .bk-field {
        margin-bottom: 20px;
    }

    .bk-field-label {
        display: block;
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 10px;
    }

    .bk-counter {
        display: flex;
        align-items: center;
        gap: 0;
        width: fit-content;
        border: 1.5px solid var(--viator-border);
        border-radius: 10px;
        overflow: hidden;
    }

    .bk-counter-btn {
        width: 44px;
        height: 44px;
        background: var(--viator-light);
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        font-weight: 600;
        color: var(--viator-dark);
        transition: background 0.15s;
    }

        .bk-counter-btn:hover {
            background: var(--viator-green-light);
            color: var(--viator-green);
        }

    .bk-counter-input {
        width: 64px;
        height: 44px;
        text-align: center;
        border: none;
        border-left: 1.5px solid var(--viator-border);
        border-right: 1.5px solid var(--viator-border);
        font-size: 1rem;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        outline: none;
    }

    .bk-price-calc {
        background: var(--viator-light);
        border: 1px solid var(--viator-border);
        border-radius: 10px;
        padding: 16px 20px;
    }

    .bk-price-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        color: var(--viator-gray);
        padding-bottom: 12px;
        margin-bottom: 12px;
        border-bottom: 1px solid var(--viator-border);
    }

    .bk-price-total {
        display: flex;
        justify-content: space-between;
        font-weight: 700;
        font-size: 1.1rem;
    }
</style>

@section Scripts {
    <script>
        const pricePerPerson = @Model.PricePerPerson;
        const maxSpots = @availableSpots;

        function changeCount(delta) {
            const input = document.getElementById('peopleInput');
            let val = parseInt(input.value) + delta;
            val = Math.max(1, Math.min(val, maxSpots));
            input.value = val;
            updatePrice(val);
        }

        document.getElementById('peopleInput').addEventListener('input', function() {
            let val = parseInt(this.value) || 1;
            val = Math.max(1, Math.min(val, maxSpots));
            this.value = val;
            updatePrice(val);
        });

        function updatePrice(count) {
            const total = (count * pricePerPerson).toFixed(2);
            document.getElementById('priceLabel').textContent = `${count} × ${pricePerPerson.toFixed(2)} €`;
            document.getElementById('totalDisplay').textContent = `${total} €`;
            document.getElementById('totalBig').textContent = `${total} €`;
        }
    </script>
}
