@model IEnumerable<Tourism.Web.Models.ViewModels.BookingViewModel>
@{
    ViewData["Title"] = "Моят профил";
}

<div class="container my-4">
    <h1 class="mb-4">Моят профил</h1>

    <!-- Профил инфо -->
    <div class="card shadow-sm p-4 mb-4">
        <div class="row">
            <div class="col-md-4 text-center">
                <i class="bi bi-person-circle" style="font-size: 5rem; color: #6c757d;"></i>
                <h4 class="mt-2">@ViewBag.UserEmail</h4>
            </div>
            <div class="col-md-8">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card text-center border-primary">
                            <div class="card-body">
                                <h3 class="text-primary">@ViewBag.TotalTrips</h3>
                                <p class="mb-0">Пътувания</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-success">
                            <div class="card-body">
                                <h3 class="text-success">@Model.Count()</h3>
                                <p class="mb-0">Резервации</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-info">
                            <div class="card-body">
                                <h3 class="text-info">@(((decimal)ViewBag.TotalSpent).ToString("C"))</h3>
                                <p class="mb-0">Общо похарчени</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- История на резервациите -->
    <h3 class="mb-3">История на пътуванията</h3>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Все още нямате пътувания. <a asp-controller="Tours" asp-action="Index">Разгледайте маршрутите</a>.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var booking in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">@booking.TourTitle</h5>
                                @{
                                    var badgeClass = booking.Status switch
                                    {
                                        Tourism.Data.Models.Enums.BookingStatus.Confirmed => "badge bg-success",
                                        Tourism.Data.Models.Enums.BookingStatus.Cancelled => "badge bg-danger",
                                        Tourism.Data.Models.Enums.BookingStatus.Completed => "badge bg-secondary",
                                        _ => "badge bg-warning text-dark"
                                    };
                                }
                                <span class="@badgeClass">@booking.Status</span>
                            </div>
                            <p class="text-muted mb-1"><i class="bi bi-geo-alt"></i> @booking.DestinationName</p>
                            <p class="mb-1"><i class="bi bi-calendar"></i> @booking.TourStartDate.ToString("dd.MM.yyyy")</p>
                            <p class="mb-1"><i class="bi bi-people"></i> @booking.NumberOfPeople човека</p>
                            <p class="mb-0"><strong>@booking.TotalPrice.ToString("C")</strong></p>
                        </div>
                        <div class="card-footer">
                            <small class="text-muted">Резервирано на @booking.BookedAt.ToString("dd.MM.yyyy HH:mm")</small>
                            <a asp-controller="Tours" asp-action="Details" asp-route-id="@booking.TourId"
                               class="btn btn-outline-primary btn-sm float-end">Виж маршрута</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
