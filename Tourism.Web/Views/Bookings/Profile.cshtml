@model IEnumerable<Tourism.Web.Models.ViewModels.BookingViewModel>
@{
    ViewData["Title"] = ViewBag.PageTitle ?? "My Profile";
    var isOwnProfile = ViewBag.PageTitle == null;
}

<style>
    .prof-hero {
        background: linear-gradient(135deg,#00AA6C 0%,#008A57 100%);
        padding: 48px 0 80px;
        margin-bottom: -60px;
    }

    .prof-avatar {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.4rem;
        border: 4px solid #fff;
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        flex-shrink: 0;
    }

    .prof-name {
        font-size: 1.4rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 2px;
    }

    .prof-email {
        font-size: .85rem;
        color: rgba(255,255,255,.75);
    }

    .prof-card {
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 16px;
        padding: 28px;
        margin-bottom: 28px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
        margin-top: 24px;
    }

    .stat-item {
        text-align: center;
        padding: 16px 8px;
        border: 1px solid var(--viator-border);
        border-radius: 12px;
        background: #FAFAFA;
    }

    .stat-val {
        font-size: 1.7rem;
        font-weight: 800;
        line-height: 1;
    }

    .stat-lbl {
        font-size: .78rem;
        color: var(--viator-gray);
        margin-top: 4px;
        font-weight: 500;
    }

    .bk-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .bk-item {
        border: 1px solid var(--viator-border);
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s,transform .2s;
        background: #fff;
    }

        .bk-item:hover {
            box-shadow: 0 4px 18px rgba(0,0,0,.09);
            transform: translateY(-1px);
        }

    .bk-item-body {
        padding: 16px 20px;
    }

    .bk-item-footer {
        padding: 10px 20px;
        background: #FAFAFA;
        border-top: 1px solid var(--viator-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .bk-title {
        font-weight: 700;
        font-size: .97rem;
        color: var(--viator-dark);
        margin-bottom: 8px;
    }

    .bk-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font-size: .82rem;
        color: var(--viator-gray);
    }

        .bk-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

    .bk-price {
        font-weight: 700;
        font-size: 1rem;
        color: var(--viator-dark);
    }

    .badge-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .s-confirmed {
        background: var(--viator-green-light);
        color: var(--viator-green);
    }

    .s-pending {
        background: #FEF3C7;
        color: #D97706;
    }

    .s-cancelled {
        background: #FEE2E2;
        color: #DC2626;
    }

    .s-completed {
        background: #F3F4F6;
        color: #6B7280;
    }

    .btn-view {
        background: var(--viator-green);
        color: #fff !important;
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: .78rem;
        text-decoration: none;
        transition: background .15s;
    }

        .btn-view:hover {
            background: var(--viator-green-dark);
        }

    @@media(max-width:600px) {
        .stat-grid {
            grid-template-columns: repeat(3,1fr)
        }
    }
</style>

<!-- Hero banner -->
<div class="prof-hero">
    <div class="container">
        <div style="display:flex;align-items:center;gap:20px">
            <div class="prof-avatar"><i class="bi bi-person-fill"></i></div>
            <div>
                <div class="prof-name">@ViewBag.DisplayName</div>
                <div class="prof-email">@ViewBag.UserEmail</div>
            </div>
        </div>
    </div>
</div>

<div class="container" style="padding-bottom:60px">

    <!-- Stats card -->
    <div class="prof-card">
        <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--viator-gray);margin-bottom:4px">Overview</div>
        <div class="stat-grid">
            <div class="stat-item">
                <div class="stat-val" style="color:var(--viator-green)">@ViewBag.TotalTrips</div>
                <div class="stat-lbl">Confirmed Trips</div>
            </div>
            <div class="stat-item">
                <div class="stat-val" style="color:#3B82F6">@Model.Count()</div>
                <div class="stat-lbl">Total Bookings</div>
            </div>
            <div class="stat-item">
                <div class="stat-val" style="color:#F59E0B;font-size:1.3rem">@(((decimal)ViewBag.TotalSpent).ToString("C"))</div>
                <div class="stat-lbl">Total Spent</div>
            </div>
        </div>
    </div>

    <!-- Bookings list -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h2 style="font-size:1.25rem;font-weight:800;margin:0">My Bookings</h2>
        @if (isOwnProfile)
        {
            <a asp-controller="Tours" asp-action="Index" class="btn-view" style="padding:8px 16px;font-size:.82rem">
                <i class="bi bi-compass me-1"></i> Browse Tours
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;background:#fff;border:1px solid var(--viator-border);border-radius:16px;color:var(--viator-gray)">
            <div style="font-size:3rem;margin-bottom:12px">🗺️</div>
            <p style="margin-bottom:16px">No bookings yet.</p>
            <a asp-controller="Tours" asp-action="Index" class="btn-view" style="padding:10px 24px;font-size:.88rem">Browse Tours</a>
        </div>
    }
    else
    {
        <div class="bk-list">
            @foreach (var b in Model)
            {
                var sc = b.Status switch
                {
                    Tourism.Data.Models.Enums.BookingStatus.Confirmed => "s-confirmed",
                    Tourism.Data.Models.Enums.BookingStatus.Cancelled => "s-cancelled",
                    Tourism.Data.Models.Enums.BookingStatus.Completed => "s-completed",
                    _ => "s-pending"
                };
                var st = b.Status switch
                {
                    Tourism.Data.Models.Enums.BookingStatus.Confirmed => "✅ Confirmed",
                    Tourism.Data.Models.Enums.BookingStatus.Cancelled => "❌ Cancelled",
                    Tourism.Data.Models.Enums.BookingStatus.Completed => "🏁 Completed",
                    _ => "⏳ Pending"
                };
                <div class="bk-item">
                    <div class="bk-item-body">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:10px">
                            <div class="bk-title">@b.TourTitle</div>
                            <span class="badge-pill @sc">@st</span>
                        </div>
                        <div class="bk-meta">
                            <span><i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @b.DestinationName</span>
                            <span><i class="bi bi-calendar3"></i> @b.TourStartDate.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                            <span><i class="bi bi-people"></i> @b.NumberOfPeople @(b.NumberOfPeople == 1 ? "person" : "people")</span>
                        </div>
                    </div>
                    <div class="bk-item-footer">
                        <div>
                            <div class="bk-price">@b.TotalPrice.ToString("C")</div>
                            <div style="font-size:.75rem;color:var(--viator-gray)">Booked @b.BookedAt.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                        </div>
                        <a asp-controller="Tours" asp-action="Details" asp-route-id="@b.TourId" class="btn-view">
                            View Tour
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>