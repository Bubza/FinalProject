@model IEnumerable<Tourism.Web.Models.ViewModels.BookingViewModel>
@using System.Globalization
@{
    ViewData["Title"] = ViewBag.PageTitle ?? "My Profile";
    var isOwnProfile = ViewBag.PageTitle == null;
    decimal totalSpent = (decimal)ViewBag.TotalSpent;
}

<style>
    .prof-hero {
        background: linear-gradient(135deg,#00AA6C 0%,#008A57 100%);
        padding: 40px 0 70px;
        margin-bottom: -50px;
    }

    .prof-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.2rem;
        border: 4px solid #fff;
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        flex-shrink: 0;
    }

    .prof-name {
        font-size: 1.3rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 2px;
    }

    .prof-email {
        font-size: .82rem;
        color: rgba(255,255,255,.75);
    }

    .prof-card {
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 14px;
        margin-top: 20px;
    }

    .stat-item {
        text-align: center;
        padding: 14px 8px;
        border: 1px solid var(--viator-border);
        border-radius: 12px;
        background: #FAFAFA;
    }

    .stat-val {
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    .stat-lbl {
        font-size: .75rem;
        color: var(--viator-gray);
        margin-top: 4px;
        font-weight: 500;
    }

    /* Compact booking rows */
    .bk-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .bk-row {
        display: flex;
        align-items: center;
        gap: 14px;
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 12px;
        padding: 14px 18px;
        transition: box-shadow .2s, transform .2s;
    }

        .bk-row:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,.08);
            transform: translateY(-1px);
        }

    .bk-row-main {
        flex: 1;
        min-width: 0;
    }

    .bk-row-title {
        font-weight: 700;
        font-size: .93rem;
        color: var(--viator-dark);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bk-row-meta {
        font-size: .78rem;
        color: var(--viator-gray);
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 4px;
    }

        .bk-row-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

    .bk-row-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
        flex-shrink: 0;
    }

    .bk-row-price {
        font-weight: 700;
        font-size: .95rem;
        color: var(--viator-dark);
    }

    .bk-row-date {
        font-size: .72rem;
        color: var(--viator-gray);
    }

    .badge-pill {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .s-confirmed {
        background: var(--viator-green-light);
        color: var(--viator-green);
    }

    .s-pending {
        background: #FEF3C7;
        color: #D97706;
    }

    .s-cancelled {
        background: #FEE2E2;
        color: #DC2626;
    }

    .s-completed {
        background: #F3F4F6;
        color: #6B7280;
    }

    .btn-view {
        background: var(--viator-green);
        color: #fff !important;
        padding: 5px 13px;
        border-radius: 8px;
        font-weight: 600;
        font-size: .75rem;
        text-decoration: none;
        transition: background .15s;
        flex-shrink: 0;
    }

        .btn-view:hover {
            background: var(--viator-green-dark);
        }
</style>

<div class="prof-hero">
    <div class="container">
        <div style="display:flex;align-items:center;gap:20px">
            <div class="prof-avatar"><i class="bi bi-person-fill"></i></div>
            <div>
                <div class="prof-name">@ViewBag.DisplayName</div>
                <div class="prof-email">@ViewBag.UserEmail</div>
            </div>
        </div>
    </div>
</div>

<div class="container" style="padding-bottom:60px;max-width:680px">

    <div class="prof-card">
        <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--viator-gray);margin-bottom:4px">Overview</div>
        <div class="stat-grid">
            <div class="stat-item">
                <div class="stat-val" style="color:var(--viator-green)">@ViewBag.DestinationsVisited</div>
                <div class="stat-lbl">Destinations</div>
            </div>
            <div class="stat-item">
                <div class="stat-val" style="color:#3B82F6">@Model.Count()</div>
                <div class="stat-lbl">Bookings</div>
            </div>
            <div class="stat-item">
                <div class="stat-val" style="color:#F59E0B;font-size:1.2rem;">@totalSpent.ToString("N2", CultureInfo.InvariantCulture) €</div>
                <div class="stat-lbl">Total Spent</div>
            </div>
        </div>
    </div>

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <h2 style="font-size:1.15rem;font-weight:800;margin:0">My Bookings</h2>
        @if (isOwnProfile)
        {
            <a asp-controller="Tours" asp-action="Index" class="btn-view" style="padding:7px 15px;font-size:.8rem;">
                <i class="bi bi-compass me-1"></i> Browse Tours
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;background:#fff;border:1px solid var(--viator-border);border-radius:16px;color:var(--viator-gray)">
            <div style="font-size:3rem;margin-bottom:12px">🗺️</div>
            <p style="margin-bottom:16px">No bookings yet.</p>
            <a asp-controller="Tours" asp-action="Index" class="btn-view" style="padding:10px 24px;font-size:.88rem">Browse Tours</a>
        </div>
    }
    else
    {
        <div class="bk-list">
            @foreach (var b in Model)
            {
                var sc = b.Status switch
                {
                    Tourism.Data.Models.Enums.BookingStatus.Confirmed => "s-confirmed",
                    Tourism.Data.Models.Enums.BookingStatus.Cancelled => "s-cancelled",
                    Tourism.Data.Models.Enums.BookingStatus.Completed => "s-completed",
                    _ => "s-pending"
                };
                var st = b.Status switch
                {
                    Tourism.Data.Models.Enums.BookingStatus.Confirmed => "✅ Confirmed",
                    Tourism.Data.Models.Enums.BookingStatus.Cancelled => "❌ Cancelled",
                    Tourism.Data.Models.Enums.BookingStatus.Completed => "🏁 Completed",
                    _ => "⏳ Pending"
                };
                <div class="bk-row">
                    <div class="bk-row-main">
                        <div class="bk-row-title">@b.TourTitle</div>
                        <div class="bk-row-meta">
                            <span><i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @b.DestinationName</span>
                            <span><i class="bi bi-calendar3"></i> @b.TourStartDate.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</span>
                            <span><i class="bi bi-people"></i> @b.NumberOfPeople @(b.NumberOfPeople == 1 ? "person" : "people")</span>
                        </div>
                    </div>
                    <div class="bk-row-right">
                        <span class="badge-pill @sc">@st</span>
                        <div class="bk-row-price">@b.TotalPrice.ToString("N2", CultureInfo.InvariantCulture) €</div>
                        <div class="bk-row-date">@b.BookedAt.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</div>
                    </div>
                    <a asp-controller="Tours" asp-action="Details" asp-route-id="@b.TourId" class="btn-view">
                        View
                    </a>
                </div>
            }
        </div>
    }
</div>

@if (isOwnProfile && ViewBag.MyReviews != null)
{
    var reviews = (IEnumerable<Tourism.Data.Models.Entities.Review>)ViewBag.MyReviews;
    <div class="container" style="padding-bottom:60px;margin-top:-40px;max-width:680px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
            <h2 style="font-size:1.15rem;font-weight:800;margin:0">My Reviews</h2>
        </div>

        @if (!reviews.Any())
        {
            <div style="text-align:center;padding:40px 20px;background:#fff;border:1px solid var(--viator-border);border-radius:16px;color:var(--viator-gray)">
                <div style="font-size:2.5rem;margin-bottom:10px">⭐</div>
                <p style="margin-bottom:14px;font-size:.9rem;">You haven't written any reviews yet.</p>
                <a asp-controller="Tours" asp-action="Index" class="btn-view" style="padding:8px 20px;font-size:.82rem;">Find a tour to review</a>
            </div>
        }
        else
        {
            <div class="bk-list">
                @foreach (var r in reviews)
                {
                    <div class="bk-row">
                        <div class="bk-row-main">
                            <div class="bk-row-title">@r.Tour?.Title</div>
                            <div class="bk-row-meta">
                                <span>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= r.Rating)
                                        {
                                            <i class="bi bi-star-fill" style="color:#F59E0B;font-size:.8rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star" style="color:#D1D5DB;font-size:.8rem;"></i>
                                        }
                                    }
                                    <span style="margin-left:4px;font-weight:600;color:var(--viator-dark);">@r.Rating/5</span>
                                </span>
                                <span><i class="bi bi-calendar3"></i> @r.CreatedAt.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</span>
                                @if (!string.IsNullOrWhiteSpace(r.Comment))
                                {
                                    <span style="color:var(--viator-dark);font-style:italic;">"@r.Comment"</span>
                                }
                            </div>
                        </div>
                        <a asp-controller="Tours" asp-action="Details" asp-route-id="@r.TourId" class="btn-view">
                            View Tour
                        </a>
                    </div>
                }
            </div>
        }
    </div>
}