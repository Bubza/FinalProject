@model Tourism.Web.Models.ViewModels.DestinationViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Destinations" asp-action="Index">Destinations</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Name">
            }
            <h1>@Model.Name</h1>
            <p class="text-muted fs-5"><i class="bi bi-flag"></i> @Model.Country</p>
            <p>@Model.Description</p>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h4 class="text-primary">@Model.TourCount tours</h4>
                <p>Discover our tours in @Model.Name</p>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Tours in @Model.Name</h3>

    @if (ViewBag.Tours != null && ((IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>)ViewBag.Tours).Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tour in (IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>)ViewBag.Tours)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="card-img-top" alt="@tour.Title" style="height:200px;object-fit:cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@tour.Title</h5>
                            <p class="text-muted"><i class="bi bi-calendar"></i> @tour.DurationDays days</p>
                            <p class="card-text">@tour.Description.Substring(0, Math.Min(80, tour.Description.Length))...</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <strong class="text-primary">@tour.PricePerPerson.ToString("C")</strong>
                            <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id"
                               class="btn btn-outline-primary btn-sm">Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">No tours available for this destination yet.</div>
    }
</div>