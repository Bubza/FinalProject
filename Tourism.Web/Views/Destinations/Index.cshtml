@model IEnumerable<Tourism.Web.Models.ViewModels.DestinationViewModel>
@{
    ViewData["Title"] = "Дестинации";
}

<div class="container my-4">
    <h1 class="mb-4">Дестинации</h1>

    <!-- Филтри -->
    <form method="get" class="row g-3 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" class="form-control" placeholder="Търси по име или държава..."
                   value="@Context.Request.Query["search"]" />
        </div>
        <div class="col-md-3">
            <select name="country" class="form-select">
                <option value="">Всички държави</option>
                @foreach (var c in (List<string>)ViewBag.Countries)
                {
                    <option value="@c" selected="@(Context.Request.Query["country"] == c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Търси</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Изчисти</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Няма намерени дестинации.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var dest in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(dest.ImageUrl))
                        {
                            <img src="@dest.ImageUrl" class="card-img-top" alt="@dest.Name" style="height:200px;object-fit:cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@dest.Name</h5>
                            <p class="text-muted mb-1"><i class="bi bi-flag"></i> @dest.Country</p>
                            <p class="card-text">@dest.Description.Substring(0, Math.Min(100, dest.Description.Length))...</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <span class="text-primary fw-bold">@dest.TourCount маршрута</span>
                            <a asp-action="Details" asp-route-id="@dest.Id" class="btn btn-outline-primary btn-sm">Разгледай</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
