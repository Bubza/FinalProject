<style>
    :root {
        --viator-green: #00AA6C;
        --viator-green-dark: #008A57;
        --viator-green-light: #E6F7F1;
        --viator-dark: #1A1A1A;
        --viator-gray: #6B7280;
        --viator-border: #E5E7EB;
        --radius: 12px;
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    }

    .btn-viator {
        background: var(--viator-green);
        color: #fff !important;
        border: none;
        padding: 9px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-viator:hover {
            background: var(--viator-green-dark);
        }

    .tour-card {
        border-radius: var(--radius);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--viator-border);
        transition: box-shadow 0.2s,transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .tour-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }

    .tour-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .tour-card-img-placeholder {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg,#e0f2eb,#c5e8d8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.5rem;
    }

    .tour-card-body {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .tour-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        color: var(--viator-gray);
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .tour-card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .tour-card-desc {
        font-size: 0.85rem;
        color: var(--viator-gray);
        flex: 1;
        margin-bottom: 12px;
    }

    .tour-card-footer {
        padding: 14px 16px;
        border-top: 1px solid var(--viator-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tour-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--viator-dark);
    }
</style>
@model IEnumerable<Tourism.Web.Models.ViewModels.DestinationViewModel>
@{
    ViewData["Title"] = "Destinations";
}

<div class="container my-4">
    <h1 class="mb-3" style="font-size:1.6rem;font-weight:700">Destinations</h1>

    @{
        var qSearch = Context.Request.Query["search"].ToString();
        var qCountry = Context.Request.Query["country"].ToString();
    }

    <form method="get" id="destForm">
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:1rem">
            <!-- Search input pill -->
            <div style="position:relative;flex:1;min-width:220px;max-width:420px">
                <i class="bi bi-search" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#6B7280"></i>
                <input type="text" name="search" value="@qSearch" placeholder="Search by name or country..."
                       style="width:100%;padding:9px 16px 9px 40px;border:1.5px solid #E5E7EB;border-radius:50px;font-size:0.875rem;outline:none;font-family:'Poppins',sans-serif;transition:border-color .15s"
                       onfocus="this.style.borderColor='#1A1A1A'" onblur="this.style.borderColor='#E5E7EB'" />
            </div>

            <!-- Country dropdown pill (custom) -->
            <input type="hidden" name="country" id="countryHidden" value="@qCountry" />
            <div style="position:relative" id="countryDropWrap">
                <button type="button" id="countryDropBtn"
                        style="border:1.5px solid #E5E7EB;border-radius:50px;padding:8px 30px 8px 16px;font-size:0.85rem;font-family:'Poppins',sans-serif;outline:none;cursor:pointer;background:#fff;color:#1A1A1A;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;transition:border-color .15s"
                        onmouseover="this.style.borderColor='#1A1A1A'" onmouseout="if(!document.getElementById('countryDropList').classList.contains('open'))this.style.borderColor='#E5E7EB'">
                    <span id="countryDropLabel">@(string.IsNullOrEmpty(qCountry) ? "All countries" : qCountry)</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" style="flex-shrink:0"><path fill="#6B7280" d="M7 10l5 5 5-5z" /></svg>
                </button>
                <ul id="countryDropList"
                    style="display:none;position:absolute;top:calc(100% + 6px);left:0;min-width:170px;background:#fff;border:1.5px solid #E5E7EB;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);padding:6px 0;z-index:999;list-style:none;margin:0">
                    <li data-val="" style="padding:9px 18px;font-size:0.85rem;cursor:pointer;font-family:'Poppins',sans-serif;@(string.IsNullOrEmpty(qCountry) ? "background:#E6F7F1;color:#00AA6C;font-weight:600" : "color:#1A1A1A")"
                        onmouseover="this.style.background='#F3F4F6'" onmouseout="this.style.background='@(string.IsNullOrEmpty(qCountry) ? "#E6F7F1" : "transparent")'">
                        All countries
                    </li>
                    @foreach (var c in (List<string>)ViewBag.Countries)
                    {
                        var isActive = qCountry == c;
                        <li data-val="@c" style="padding:9px 18px;font-size:0.85rem;cursor:pointer;font-family:'Poppins',sans-serif;@(isActive ? "background:#E6F7F1;color:#00AA6C;font-weight:600" : "color:#1A1A1A")"
                            onmouseover="this.style.background='#F3F4F6'" onmouseout="this.style.background='@(isActive ? "#E6F7F1" : "transparent")'">
                            @c
                        </li>
                    }
                </ul>
            </div>
            <script>
                (function () {
                    var btn = document.getElementById('countryDropBtn');
                    var list = document.getElementById('countryDropList');
                    var hidden = document.getElementById('countryHidden');
                    var label = document.getElementById('countryDropLabel');
                    btn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        var open = list.style.display === 'block';
                        list.style.display = open ? 'none' : 'block';
                        list.classList.toggle('open', !open);
                        btn.style.borderColor = open ? '#E5E7EB' : '#1A1A1A';
                    });
                    list.querySelectorAll('li').forEach(function (li) {
                        li.addEventListener('click', function () {
                            hidden.value = this.dataset.val;
                            label.textContent = this.dataset.val || 'All countries';
                            list.style.display = 'none';
                            list.classList.remove('open');
                            document.getElementById('destForm').submit();
                        });
                    });
                    document.addEventListener('click', function () {
                        list.style.display = 'none';
                        list.classList.remove('open');
                        btn.style.borderColor = '#E5E7EB';
                    });
                })();
            </script>

            <!-- Clear pill -->
            @if (!string.IsNullOrEmpty(qSearch) || !string.IsNullOrEmpty(qCountry))
            {
                <a asp-action="Index" style="font-size:0.85rem;font-weight:600;color:#DC2626;text-decoration:none;white-space:nowrap;padding:7px 12px;border:1.5px solid #FECACA;border-radius:50px;background:#FEF2F2">Clear</a>
            }

            <!-- Search button -->
            <button type="submit"
                    style="background:#00AA6C;color:#fff;border:none;padding:9px 22px;border-radius:50px;font-weight:600;font-size:0.875rem;cursor:pointer;font-family:'Poppins',sans-serif;white-space:nowrap;transition:background .15s"
                    onmouseover="this.style.background='#008A57'" onmouseout="this.style.background='#00AA6C'">
                Search
            </button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No destinations found.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var dest in Model)
            {
                <div class="col">
                    <div class="tour-card">
                        @if (!string.IsNullOrEmpty(dest.ImageUrl))
                        {
                            <img src="@dest.ImageUrl" class="tour-card-img" alt="@dest.Name" />
                        }
                        else
                        {
                            <div class="tour-card-img-placeholder"><i class="bi bi-map"></i></div>
                        }
                        <div class="tour-card-body">
                            <div class="tour-card-meta">
                                <span><i class="bi bi-flag-fill" style="color:var(--viator-green)"></i> @dest.Country</span>
                            </div>
                            <h3 class="tour-card-title">@dest.Name</h3>
                            <p class="tour-card-desc">
                                @(dest.Description.Length > 90 ? dest.Description.Substring(0, 90) + "…" : dest.Description)
                            </p>
                        </div>
                        <div class="tour-card-footer">
                            <div class="tour-price" style="font-size:1rem">
                                <i class="bi bi-compass" style="color:var(--viator-green)"></i>
                                <strong style="color:var(--viator-green)">@dest.TourCount tours</strong>
                            </div>
                            <a asp-action="Details" asp-route-id="@dest.Id" class="btn-viator">Explore</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>