<style>
    :root {
        --viator-green: #00AA6C;
        --viator-green-dark: #008A57;
        --viator-green-light: #E6F7F1;
        --viator-dark: #1A1A1A;
        --viator-gray: #6B7280;
        --viator-border: #E5E7EB;
        --radius: 12px;
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    }

    .btn-viator {
        background: var(--viator-green);
        color: #fff !important;
        border: none;
        padding: 9px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-viator:hover {
            background: var(--viator-green-dark);
        }

    .tour-card {
        border-radius: var(--radius);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--viator-border);
        transition: box-shadow 0.2s, transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .tour-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }

    .tour-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .tour-card-img-placeholder {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg, #e0f2eb, #c5e8d8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.5rem;
    }

    .tour-card-body {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .tour-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        color: var(--viator-gray);
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .tour-card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .tour-rating {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

        .tour-rating .stars {
            color: #F59E0B;
        }

        .tour-rating .count {
            color: var(--viator-gray);
        }

    .tour-card-desc {
        font-size: 0.85rem;
        color: var(--viator-gray);
        flex: 1;
        margin-bottom: 12px;
    }

    .tour-card-footer {
        padding: 14px 16px;
        border-top: 1px solid var(--viator-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tour-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--viator-dark);
    }
</style>
@model IEnumerable<Tourism.Web.Models.ViewModels.DestinationViewModel>
@{
    ViewData["Title"] = "Дестинации";
}

<div class="container my-4">
    <h1 class="mb-4">Дестинации</h1>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" class="form-control" placeholder="Търси по име или държава..."
                   value="@Context.Request.Query["search"]" />
        </div>
        <div class="col-md-3">
            <select name="country" class="form-select">
                <option value="">Всички държави</option>
                @foreach (var c in (List<string>)ViewBag.Countries)
                {
                    <option value="@c" selected="@(Context.Request.Query["country"] == c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Търси</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Изчисти</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Няма намерени дестинации.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var dest in Model)
            {
                <div class="col">
                    <div class="tour-card">
                        @if (!string.IsNullOrEmpty(dest.ImageUrl))
                        {
                            <img src="@dest.ImageUrl" class="tour-card-img" alt="@dest.Name" />
                        }
                        else
                        {
                            <div class="tour-card-img-placeholder">
                                <i class="bi bi-map"></i>
                            </div>
                        }
                        <div class="tour-card-body">
                            <div class="tour-card-meta">
                                <span><i class="bi bi-flag-fill" style="color:var(--viator-green)"></i> @dest.Country</span>
                            </div>
                            <h3 class="tour-card-title">@dest.Name</h3>
                            <p class="tour-card-desc">
                                @(dest.Description.Length > 90 ? dest.Description.Substring(0, 90) + "…" : dest.Description)
                            </p>
                        </div>
                        <div class="tour-card-footer">
                            <div class="tour-price" style="font-size:1rem">
                                <i class="bi bi-compass" style="color:var(--viator-green)"></i>
                                <strong style="color:var(--viator-green)">@dest.TourCount маршрута</strong>
                            </div>
                            <a asp-action="Details" asp-route-id="@dest.Id" class="btn-viator">Разгледай</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
