<style>
    :root {
        --viator-green: #00AA6C;
        --viator-green-dark: #008A57;
        --viator-green-light: #E6F7F1;
        --viator-dark: #1A1A1A;
        --viator-gray: #6B7280;
        --viator-border: #E5E7EB;
        --radius: 12px;
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    }

    .btn-viator {
        background: var(--viator-green);
        color: #fff !important;
        border: none;
        padding: 9px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-viator:hover {
            background: var(--viator-green-dark);
        }

    .tour-card {
        border-radius: var(--radius);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--viator-border);
        transition: box-shadow 0.2s,transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .tour-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }

    .tour-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .tour-card-img-placeholder {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg,#e0f2eb,#c5e8d8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.5rem;
    }

    .tour-card-body {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .tour-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        color: var(--viator-gray);
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .tour-card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .tour-card-desc {
        font-size: 0.85rem;
        color: var(--viator-gray);
        flex: 1;
        margin-bottom: 12px;
    }

    .tour-card-footer {
        padding: 14px 16px;
        border-top: 1px solid var(--viator-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tour-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--viator-dark);
    }
</style>
@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@{
    ViewData["Title"] = "Saved Tours";
}

<div class="container my-4">
    <h1 class="mb-4">Saved Tours</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No saved tours yet. <a asp-controller="Tours" asp-action="Index">Browse tours</a> and add some!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var tour in Model)
            {
                <div class="col">
                    <div class="tour-card">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="tour-card-img" alt="@tour.Title" />
                        }
                        else
                        {
                            <div class="tour-card-img-placeholder"><i class="bi bi-map"></i></div>
                        }
                        <div class="tour-card-body">
                            <div class="tour-card-meta">
                                <span><i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @tour.DestinationName</span>
                                <span><i class="bi bi-clock"></i> @tour.DurationDays days</span>
                            </div>
                            <h3 class="tour-card-title">@tour.Title</h3>
                            <p class="tour-card-desc">
                                @(tour.Description.Length > 90 ? tour.Description.Substring(0, 90) + "..." : tour.Description)
                            </p>
                        </div>
                        <div class="tour-card-footer">
                            <div class="tour-price">
                                @tour.PricePerPerson.ToString("C")
                                <small>/ person</small>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn-viator">
                                    View Details
                                </a>
                                <form asp-controller="Favorites" asp-action="Remove"
                                      asp-route-id="@tour.Id"
                                      asp-route-returnUrl="/Favorites"
                                      method="post" class="d-inline m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>