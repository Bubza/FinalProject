@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@using System.Globalization
@{
    ViewData["Title"] = "Saved Tours";
}

<style>
    .tour-card {
        border-radius: var(--radius);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--viator-border);
        transition: box-shadow 0.2s, transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .tour-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }

    .tour-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        background: var(--viator-green-light);
    }

    .tour-card-img-placeholder {
        width: 100%;
        height: 200px;
        background: var(--viator-green-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--viator-green);
        font-size: 2.5rem;
    }

    .tour-card-body {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 130px;
    }

    .tour-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        color: var(--viator-gray);
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .tour-card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .tour-card-desc {
        font-size: 0.85rem;
        color: var(--viator-gray);
        flex: 1;
        margin-bottom: 0;
    }

    .tour-card-footer {
        padding: 14px 16px;
        border-top: 1px solid var(--viator-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tour-price {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--viator-dark);
    }

    .btn-viator {
        background: var(--viator-green);
        color: #fff !important;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-viator:hover {
            background: var(--viator-green-dark);
        }
</style>

<div class="container my-4">
    <h1 class="mb-4">Saved Tours</h1>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;background:#fff;border:1px solid var(--viator-border);border-radius:16px;color:var(--viator-gray)">
            <div style="font-size:3rem;margin-bottom:12px">&#9825;</div>
            <p style="margin-bottom:16px">No saved tours yet.</p>
            <a asp-controller="Tours" asp-action="Index" class="btn-viator" style="padding:10px 24px;">Browse tours</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var tour in Model)
            {
                <div class="col">
                    <div class="tour-card">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl"
                                 class="tour-card-img"
                                 alt="@tour.Title"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="tour-card-img-placeholder" style="display:none;">
                                <i class="bi bi-map"></i>
                            </div>
                        }
                        else
                        {
                            <div class="tour-card-img-placeholder"><i class="bi bi-map"></i></div>
                        }
                        <div class="tour-card-body">
                            <div class="tour-card-meta">
                                <span><i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @tour.DestinationName</span>
                                <span><i class="bi bi-clock"></i> @tour.DurationDays days</span>
                            </div>
                            <h3 class="tour-card-title">@tour.Title</h3>
                            <p class="tour-card-desc">
                                @(tour.Description.Length > 90 ? tour.Description.Substring(0, 90) + "..." : tour.Description)
                            </p>
                        </div>
                        <div class="tour-card-footer">
                            <div class="tour-price">
                                @tour.PricePerPerson.ToString("N2", CultureInfo.InvariantCulture) €
                                <small style="font-weight:400;font-size:.8rem;color:var(--viator-gray)">/ person</small>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn-viator">
                                    View Details
                                </a>
                                <form asp-controller="Favorites" asp-action="Remove"
                                      asp-route-id="@tour.Id"
                                      asp-route-returnUrl="/Favorites"
                                      method="post" class="d-inline m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>