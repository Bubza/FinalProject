@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@{
    ViewData["Title"] = "Любими маршрути";
}

<div class="container my-4">
    <h1 class="mb-4">Любими маршрути</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Нямате любими маршрути. <a asp-controller="Tours" asp-action="Index">Разгледайте маршрутите</a> и добавете някои!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tour in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="card-img-top" alt="@tour.Title" style="height:200px;object-fit:cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@tour.Title</h5>
                            <p class="text-muted mb-1"><i class="bi bi-geo-alt"></i> @tour.DestinationName</p>
                            <p class="text-muted mb-2"><i class="bi bi-calendar"></i> @tour.DurationDays дни</p>
                            <p class="card-text">@tour.Description.Substring(0, Math.Min(80, tour.Description.Length))...</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <strong class="text-primary">@tour.PricePerPerson.ToString("C")</strong>
                            <div>
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id"
                                   class="btn btn-outline-primary btn-sm">Детайли</a>
                                <form asp-controller="Favorites" asp-action="Remove" asp-route-id="@tour.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Премахни</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>