@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@{
    ViewData["Title"] = "Home";
}

<!-- ── HERO ── -->
<section class="hero-section">
    <div class="hero-bg">
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1499678329028-101435549a4e?w=1600&auto=format&fit=crop');"></div>
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&auto=format&fit=crop');"></div>
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1600&auto=format&fit=crop');"></div>
        <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
        <h1 class="hero-title">Discover something amazing,<br>near and far</h1>
        <p class="hero-subtitle">Over 500 routes chosen by real travelers</p>

        <div class="hero-search">
            <form asp-controller="Tours" asp-action="Index" method="get" class="search-bar">
                <div class="search-field search-field-main">
                    <i class="bi bi-search"></i>
                    <input type="text" id="homeSearchInput" name="search" placeholder="Search destination or tour..." class="search-input" autocomplete="off" />
                </div>
                <div class="search-field search-field-price" style="min-width:200px">
                    <i class="bi bi-calendar3" style="flex-shrink:0"></i>
                    <input type="text" id="heroDatePicker" placeholder="Select dates..." class="search-input" readonly style="cursor:pointer" />
                    <input type="hidden" name="startDate" id="heroStartDate" />
                    <input type="hidden" name="endDate" id="heroEndDate" />
                </div>
                <button type="submit" class="search-btn">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </form>
        </div>

        <div class="hero-badges">
            <span class="hero-badge"><i class="bi bi-shield-check"></i> Secure payment</span>
            <span class="hero-badge"><i class="bi bi-arrow-counterclockwise"></i> Free Cancellation</span>
            <span class="hero-badge"><i class="bi bi-star"></i> Verified reviews</span>
        </div>
    </div>

    <!-- Slideshow dots -->
    <div style="position:absolute;bottom:18px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10;">
        <span class="hero-dot active" data-idx="0"></span>
        <span class="hero-dot" data-idx="1"></span>
        <span class="hero-dot" data-idx="2"></span>
    </div>
</section>

<style>
    .hero-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.45);
        cursor: pointer;
        transition: background .3s, transform .3s;
    }

        .hero-dot.active {
            background: #fff;
            transform: scale(1.3);
        }
</style>

<script>
    (function() {
        const slides = document.querySelectorAll('.hero-slide');
        const dots   = document.querySelectorAll('.hero-dot');
        let current  = 0;

        slides[0].classList.add('active');

        function goTo(idx) {
            slides[current].classList.remove('active');
            dots[current].classList.remove('active');
            current = idx;
            slides[current].classList.add('active');
            dots[current].classList.add('active');
        }

        dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.idx)));

        setInterval(() => goTo((current + 1) % slides.length), 5000);
    })();
</script>

<!-- ── WHY US ── -->
<section class="why-section">
    <div class="container">
        <div class="why-grid">
            <div class="why-item">
                <div class="why-icon"><i class="bi bi-telephone"></i></div>
                <div>
                    <strong>24/7 Support</strong>
                    <p>Always available</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon why-icon-teal"><i class="bi bi-lightbulb"></i></div>
                <div>
                    <strong>Unique experiences</strong>
                    <p>Discover hidden gems</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon why-icon-yellow"><i class="bi bi-star"></i></div>
                <div>
                    <strong>Verified reviews</strong>
                    <p>Real ratings</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon why-icon-blue"><i class="bi bi-calendar-check"></i></div>
                <div>
                    <strong>Flexible booking</strong>
                    <p>Change any time</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── FEATURED TOURS ── -->
<section class="container section-gap">
    <div class="section-header">
        <div>
            <h2 class="section-title">Featured Tours</h2>
            <p class="section-subtitle">The most popular experiences this week</p>
        </div>
        <a asp-controller="Tours" asp-action="Index" class="btn-viator-outline">
            View all <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var tour in Model)
            {
                <div class="col">
                    <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" style="text-decoration:none;color:inherit;display:block;height:100%" class="tour-card">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="tour-card-img" alt="@tour.Title" />
                        }
                        else
                        {
                            <div class="tour-card-img-placeholder">
                                <i class="bi bi-map"></i>
                            </div>
                        }
                        <div class="tour-card-body">
                            <div class="tour-card-meta">
                                <span><i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @tour.DestinationName</span>
                                <span><i class="bi bi-clock"></i> @tour.DurationDays days</span>
                            </div>
                            <h3 class="tour-card-title">@tour.Title</h3>
                            @if (tour.ReviewCount > 0)
                            {
                                <div class="tour-rating">
                                    <span class="stars">
                                        @for (int i = 0; i < (int)Math.Round(tour.AverageRating); i++)
                                        {
                                            <text>★</text>
                                        }
                                    </span>
                                    <strong>@tour.AverageRating.ToString("0.0")</strong>
                                    <span class="count">(@tour.ReviewCount reviews)</span>
                                </div>
                            }
                            <p class="tour-card-desc">
                                @(tour.Description.Length > 90 ? tour.Description.Substring(0, 90) + "…" : tour.Description)
                            </p>
                        </div>
                        <div class="tour-card-footer">
                            <div>
                                <div class="tour-price">
                                    @tour.PricePerPerson.ToString("C")
                                    <small>/ person</small>
                                </div>
                            </div>
                            <span style="font-size:.82rem;color:var(--viator-green);font-weight:600">View Details →</span>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert-viator">
            <i class="bi bi-info-circle me-2"></i>No tours available yet.
        </div>
    }
</section>

<!-- ── TOP DESTINATIONS ── -->
@if (ViewBag.Destinations != null && ((IEnumerable<dynamic>)ViewBag.Destinations).Any())
{
    <section class="container section-gap">
        <div class="section-header">
            <div>
                <h2 class="section-title">Top Destinations</h2>
                <p class="section-subtitle">Explore the world's most loved travel spots</p>
            </div>
            <a asp-controller="Destinations" asp-action="Index" class="btn-viator-outline">
                All destinations <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:14px;">
            @foreach (var dest in (IEnumerable<dynamic>)ViewBag.Destinations)
            {
                <a asp-controller="Tours" asp-action="Index" asp-route-search="@dest.Name"
                   style="position:relative;border-radius:14px;overflow:hidden;display:block;text-decoration:none;aspect-ratio:3/4;">
                    @if (!string.IsNullOrEmpty((string)dest.ImageUrl))
                    {
                        <img src="@dest.ImageUrl" alt="@dest.Name"
                             style="width:100%;height:100%;object-fit:cover;transition:transform .3s"
                             onmouseover="this.style.transform='scale(1.05)'"
                             onmouseout="this.style.transform='scale(1)'" />
                    }
                    else
                    {
                        <div style="width:100%;height:100%;background:linear-gradient(135deg,#00AA6C,#005c3a)"></div>
                    }
                    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.65) 40%,transparent 100%)"></div>
                    <div style="position:absolute;bottom:14px;left:14px;right:14px;">
                        <div style="color:#fff;font-weight:700;font-size:.95rem;line-height:1.2;">@dest.Name</div>
                        <div style="color:rgba(255,255,255,.8);font-size:.75rem;margin-top:3px;">@dest.Country</div>
                    </div>
                </a>
            }
        </div>
    </section>
}

<!-- ── CTA BANNER ── -->
<section class="cta-section">
    <div class="container cta-content">
        <h2>Ready for your next adventure?</h2>
        <p>Register for free and get personalized recommendations</p>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-area="Identity" asp-page="/Account/Register" class="btn-viator btn-viator-white">
                Register for free
            </a>
        }
        else
        {
            <a asp-controller="Tours" asp-action="Index" class="btn-viator btn-viator-white">
                Browse Tours
            </a>
        }
    </div>
</section>

<style>
    /* ── HERO ── */
    .hero-section {
        position: relative;
        min-height: 520px;
        display: flex;
        align-items: center;
        overflow: visible;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transition: opacity 1.2s ease-in-out;
    }

        .hero-slide.active {
            opacity: 1;
        }

        .hero-slide::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(0, 60, 35, 0.52);
        }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .hero-content {
        position: relative;
        z-index: 1;
        padding: 72px 0 60px;
        text-align: center;
    }

    .hero-title {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.8rem, 4vw, 3rem);
        color: #fff;
        margin-bottom: 12px;
        line-height: 1.2;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.85);
        font-size: 1.1rem;
        margin-bottom: 36px;
    }

    .hero-search {
        margin-bottom: 24px;
        position: relative;
        z-index: 100;
    }

    .search-bar {
        background: #fff;
        border-radius: 12px;
        padding: 8px;
        display: flex;
        gap: 0;
        max-width: 700px;
        margin: 0 auto;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        overflow: visible;
    }

    .search-field {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        flex: 1;
        color: #9CA3AF;
    }

        .search-field + .search-field {
            border-left: 1px solid #E5E7EB;
        }

    .search-input {
        border: none;
        outline: none;
        width: 100%;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        color: #1A1A1A;
    }

        .search-input::placeholder {
            color: #9CA3AF;
        }

    .search-btn {
        background: var(--viator-green);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 12px 28px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s;
        font-family: 'DM Sans', sans-serif;
    }

        .search-btn:hover {
            background: var(--viator-green-dark);
        }

    .hero-badges {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .hero-badge {
        background: rgba(255,255,255,0.15);
        color: #fff;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .why-section {
        padding: 28px 0;
        border-bottom: 1px solid var(--viator-border);
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    @@media (max-width: 768px) {
        .why-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .why-item {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .why-icon {
        width: 44px;
        height: 44px;
        background: #FFF0F0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #EF4444;
        flex-shrink: 0;
    }

    .why-icon-teal {
        background: var(--viator-green-light);
        color: var(--viator-green);
    }

    .why-icon-yellow {
        background: #FEF3C7;
        color: #D97706;
    }

    .why-icon-blue {
        background: #EFF6FF;
        color: #3B82F6;
    }

    .why-item strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .why-item p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--viator-gray);
    }

    .section-gap {
        padding: 56px 0;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 32px;
    }

    .section-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.75rem;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: var(--viator-gray);
        font-size: 0.9rem;
        margin: 0;
    }

    .cta-section {
        background: linear-gradient(135deg, #0a4d35 0%, #00AA6C 100%);
        margin-top: 60px;
    }

    .cta-content {
        text-align: center;
        padding: 64px 20px;
        color: #fff;
    }

        .cta-content h2 {
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            margin-bottom: 12px;
        }

        .cta-content p {
            color: rgba(255,255,255,0.85);
            margin-bottom: 28px;
            font-size: 1.05rem;
        }

    .btn-viator-white {
        background: #fff !important;
        color: var(--viator-green) !important;
        padding: 14px 36px !important;
        font-size: 1rem !important;
    }

        .btn-viator-white:hover {
            background: #f0fdf6 !important;
        }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .flatpickr-calendar {
            font-family: 'Poppins', sans-serif !important;
            border-radius: 16px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15) !important;
            border: none !important;
        }

        .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange {
            background: #00AA6C !important;
            border-color: #00AA6C !important;
        }

        .flatpickr-day.inRange {
            background: #E6F7F1 !important;
            border-color: #E6F7F1 !important;
            color: #00AA6C !important;
        }

        .flatpickr-day:hover {
            background: #E6F7F1 !important;
        }

        .flatpickr-months .flatpickr-month {
            background: #fff !important;
            color: #1A1A1A !important;
        }

        .flatpickr-current-month {
            font-weight: 700 !important;
            font-size: 1rem !important;
        }

        .flatpickr-weekday {
            color: #6B7280 !important;
            font-weight: 600 !important;
        }

        .flatpickr-day.today {
            border-color: #00AA6C !important;
        }

        .flatpickr-prev-month svg, .flatpickr-next-month svg {
            fill: #00AA6C !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        flatpickr("#heroDatePicker", {
            mode: "range",
            minDate: "today",
            dateFormat: "Y-m-d",
            onChange: function(selectedDates) {
                document.getElementById("heroStartDate").value = selectedDates[0] ? selectedDates[0].toISOString().split("T")[0] : "";
                document.getElementById("heroEndDate").value   = selectedDates[1] ? selectedDates[1].toISOString().split("T")[0] : "";
            }
        });
    </script>

    <script>
        async function initHomeAutocomplete() {
            const input = document.getElementById("homeSearchInput");
            if (!input) return;
            const parent = input.parentElement;
            parent.style.position = "relative";

            const autocompleteService = new google.maps.places.AutocompleteService();
            const sessionToken = new google.maps.places.AutocompleteSessionToken();

            const dropdown = document.createElement("div");
            dropdown.style.cssText = "position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1000;display:none;margin-top:4px;overflow:hidden;font-family:'Poppins',sans-serif";
            parent.appendChild(dropdown);

            input.addEventListener("input", function() {
                const val = this.value.trim();
                if (val.length < 2) { dropdown.style.display = "none"; return; }
                autocompleteService.getPlacePredictions(
                    {
                        input: val,
                        types: ["(regions)"],
                        sessionToken,
                        locationBias: new google.maps.LatLngBounds(
                            new google.maps.LatLng(35.0, -10.0),
                            new google.maps.LatLng(70.0, 40.0)
                        )
                    },
                    function(predictions, status) {
                        if (status !== google.maps.places.PlacesServiceStatus.OK || !predictions) {
                            dropdown.style.display = "none"; return;
                        }
                        dropdown.innerHTML = "";
                        predictions.slice(0, 5).forEach(function(p) {
                            const item = document.createElement("div");
                            item.style.cssText = "padding:10px 16px;cursor:pointer;border-bottom:1px solid #F3F4F6;display:flex;align-items:center;gap:12px";
                            const parts = p.description.split(",");
                            const mainText = parts[0].trim();
                            const subText = parts.length > 1 ? parts[parts.length - 1].trim() : "";
                            item.innerHTML = `
                                <i class="bi bi-geo-alt-fill" style="color:#00AA6C;font-size:1.1rem;flex-shrink:0"></i>
                                <div>
                                    <div style="font-size:.88rem;font-weight:600;color:#1A1A1A">${mainText}</div>
                                    ${subText ? `<div style="font-size:.75rem;color:#6B7280;margin-top:1px">${subText}</div>` : ""}
                                </div>`;
                            item.addEventListener("mousedown", function(e) {
                                e.preventDefault();
                                input.value = p.description.split(",")[0].trim();
                                dropdown.style.display = "none";
                                input.closest("form").submit();
                            });
                            item.addEventListener("mouseover", function() { this.style.background = "#E6F7F1"; });
                            item.addEventListener("mouseout",  function() { this.style.background = ""; });
                            dropdown.appendChild(item);
                        });
                        dropdown.style.display = "block";
                    }
                );
            });

            input.addEventListener("blur",    function() { setTimeout(function() { dropdown.style.display = "none"; }, 150); });
            input.addEventListener("keydown", function(e) { if (e.key === "Escape") dropdown.style.display = "none"; });
        }
        window.initHomeMaps = initHomeAutocomplete;
    </script>
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCGQ6q74bpBejjpvAt1VQpHxZ7rtynPEy8&libraries=places&callback=initHomeMaps"></script>
}