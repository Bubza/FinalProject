@model IEnumerable<Tourism.Data.Models.Entities.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container my-4">
    <h1 class="mb-4">Bookings for My Tours</h1>

    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Tour</th>
                <th>Customer</th>
                <th>People</th>
                <th>Total</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.Tour?.Title</td>
                    <td>@b.UserId</td>
                    <td>@b.NumberOfPeople</td>
                    <td>@b.TotalPrice.ToString("0.00") €</td>
                    <td>
                        @{
                            var badgeClass = b.Status.ToString() switch
                            {
                                "Confirmed" => "bg-success",
                                "Cancelled" => "bg-danger",
                                "Completed" => "bg-secondary",
                                _ => "bg-warning text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@b.Status</span>
                    </td>
                    <td>
                        @if (b.Status == Tourism.Data.Models.Enums.BookingStatus.Pending)
                        {
                            <form asp-action="ConfirmBooking" asp-route-id="@b.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                            </form>
                            <form asp-action="CancelBooking" asp-route-id="@b.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Dashboard" class="btn btn-outline-secondary mt-2">← Dashboard</a>
</div>