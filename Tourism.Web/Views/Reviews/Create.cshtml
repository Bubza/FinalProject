@model Tourism.Web.Models.ViewModels.ReviewViewModel
@{
    ViewData["Title"] = "Напиши ревю";
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Начало</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tours" asp-action="Index">Маршрути</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tours" asp-action="Details" asp-route-id="@Model.TourId">@Model.TourTitle</a></li>
            <li class="breadcrumb-item active">Ревю</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h2 class="mb-4">Напиши ревю за "@Model.TourTitle"</h2>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TourId" />
                    <input type="hidden" asp-for="TourTitle" />

                    <div class="mb-3">
                        <label asp-for="Rating" class="form-label">Оценка (1-5)</label>
                        <select asp-for="Rating" class="form-select">
                            <option value="5">★★★★★ — Отлично</option>
                            <option value="4">★★★★☆ — Много добро</option>
                            <option value="3">★★★☆☆ — Добро</option>
                            <option value="2">★★☆☆☆ — Задоволително</option>
                            <option value="1">★☆☆☆☆ — Лошо</option>
                        </select>
                        <span asp-validation-for="Rating" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Comment" class="form-label">Коментар</label>
                        <textarea asp-for="Comment" class="form-control" rows="5" placeholder="Споделете вашето мнение..."></textarea>
                        <span asp-validation-for="Comment" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Публикувай ревюто</button>
                    <a asp-controller="Tours" asp-action="Details" asp-route-id="@Model.TourId"
                       class="btn btn-outline-secondary w-100 mt-2">Назад</a>
                </form>
            </div>
        </div>
    </div>
</div>

