@model Tourism.Web.Models.ViewModels.TourOperatorViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Начало</a></li>
            <li class="breadcrumb-item"><a asp-controller="TourOperators" asp-action="Index">Туроператори</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow-sm p-4 mb-4">
        <h1>@Model.Name</h1>
        <p>@Model.Description</p>
        <p><i class="bi bi-envelope"></i> @Model.Email</p>
        <p><i class="bi bi-telephone"></i> @Model.PhoneNumber</p>
        <p class="text-primary fw-bold">@Model.TourCount маршрута</p>
    </div>

    <h3 class="mb-3">Маршрути</h3>
    @if (ViewBag.Tours != null)
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tour in ViewBag.Tours)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@tour.Title</h5>
                            <p class="text-muted"><i class="bi bi-geo-alt"></i> @tour.DestinationName</p>
                            <p><i class="bi bi-calendar"></i> @tour.DurationDays дни</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <strong class="text-primary">@tour.PricePerPerson.ToString("C")</strong>
                            <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id"
                               class="btn btn-outline-primary btn-sm">Детайли</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

