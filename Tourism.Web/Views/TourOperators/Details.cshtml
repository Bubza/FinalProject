@model Tourism.Web.Models.ViewModels.TourOperatorViewModel
@{
    ViewData["Title"] = Model.Name;
}

<style>
    :root {
        --g: #00AA6C;
        --gd: #008A57;
        --gl: #E6F7F1;
        --dark: #1A1A1A;
        --gray: #6B7280;
        --border: #E5E7EB;
        --r: 12px;
    }

    .bc {
        display: flex;
        gap: 8px;
        align-items: center;
        font-size: .85rem;
        padding: 14px 0;
        margin: 0;
        list-style: none;
    }

        .bc li + li::before {
            content: '/';
            color: var(--border);
            margin-right: 8px;
        }

        .bc a {
            color: var(--g);
            text-decoration: none;
        }

    .tour-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
    }

    @@media(max-width:900px) {
        .tour-grid {
            grid-template-columns: repeat(2,1fr)
        }
    }

    @@media(max-width:560px) {
        .tour-grid {
            grid-template-columns: 1fr
        }
    }

    .tcard {
        border-radius: var(--r);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--border);
        transition: box-shadow .2s,transform .2s;
        display: flex;
        flex-direction: column;
    }

        .tcard:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,.11);
            transform: translateY(-2px);
        }

    .tcard-img-wrap {
        position: relative;
        overflow: hidden;
    }

    .tcard-img {
        width: 100%;
        height: 185px;
        object-fit: cover;
        display: block;
        transition: transform .3s;
    }

    .tcard:hover .tcard-img {
        transform: scale(1.04);
    }

    .tcard-img-ph {
        width: 100%;
        height: 185px;
        background: linear-gradient(135deg,#e0f2eb,#c5e8d8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--g);
        font-size: 2.5rem;
    }

    .tcard-body {
        padding: 12px 14px 8px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .tcard-rating {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: .82rem;
        margin-bottom: 5px;
    }

        .tcard-rating .star {
            color: #F59E0B;
        }

        .tcard-rating .rval {
            font-weight: 700;
        }

        .tcard-rating .rcnt {
            color: var(--gray);
        }

    .tcard-title {
        font-size: .9rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 6px;
        color: var(--dark);
        flex: 1;
    }

    .tcard-meta {
        font-size: .8rem;
        color: var(--gray);
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-bottom: 8px;
    }

        .tcard-meta span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

    .tcard-footer {
        padding: 10px 14px 12px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tcard-price-label {
        font-size: .72rem;
        color: var(--gray);
    }

    .tcard-price {
        font-size: 1rem;
        font-weight: 700;
        color: var(--dark);
    }

    .btn-details {
        background: var(--g);
        color: #fff !important;
        border: none;
        padding: 7px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: .8rem;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
    }

        .btn-details:hover {
            background: var(--gd);
        }

    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: .9rem;
        color: var(--gray);
        margin-bottom: 10px;
    }

        .info-row i {
            color: var(--g);
            font-size: 1rem;
            width: 20px;
        }
</style>

<div class="container my-4">
    <ol class="bc">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="TourOperators" asp-action="Index">Tour Operators</a></li>
        <li style="color:var(--gray)">@Model.Name</li>
    </ol>

    <!-- Operator header card -->
    <div style="border:1px solid var(--border);border-radius:16px;padding:32px;margin-bottom:36px;display:flex;gap:28px;align-items:flex-start">
        <!-- Logo -->
        <div style="flex-shrink:0">
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl" alt="@Model.Name logo" style="width:80px;height:80px;border-radius:12px;object-fit:cover;border:1px solid var(--border)" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:12px;background:var(--gl);display:flex;align-items:center;justify-content:center;font-size:2rem">🏢</div>
            }
        </div>
        <!-- Info -->
        <div style="flex:1">
            <h1 style="font-size:1.8rem;font-weight:800;margin:0 0 8px">@Model.Name</h1>
            <p style="color:var(--gray);margin-bottom:18px;line-height:1.7">@Model.Description</p>
            <div class="info-row"><i class="bi bi-envelope-fill"></i> @Model.Email</div>
            <div class="info-row"><i class="bi bi-telephone-fill"></i> @Model.PhoneNumber</div>
            <div style="margin-top:14px">
                <span style="background:var(--gl);color:var(--g);border-radius:50px;padding:6px 16px;font-size:.85rem;font-weight:700">
                    <i class="bi bi-compass"></i> @Model.TourCount tours
                </span>
            </div>
        </div>
    </div>

    <!-- Tours -->
    <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:20px">Tours by @Model.Name</h2>

    @if (ViewBag.Tours != null && ((IEnumerable<dynamic>)ViewBag.Tours).Any())
    {
        <div class="tour-grid">
            @foreach (var tour in ViewBag.Tours)
            {
                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="tcard" style="text-decoration:none;color:inherit;display:block;">
                    <div class="tcard-img-wrap">
                        @if (!string.IsNullOrEmpty((string)tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="tcard-img" alt="@tour.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="tcard-img-ph"><i class="bi bi-map"></i></div>
                        }
                    </div>
                    <div class="tcard-body">
                        @if (tour.ReviewCount > 0)
                        {
                            <div class="tcard-rating">
                                <span class="star">★</span>
                                <span class="rval">@tour.AverageRating.ToString("0.0")</span>
                                <span class="rcnt">(@tour.ReviewCount)</span>
                            </div>
                        }
                        <div class="tcard-title">@tour.Title</div>
                        <div class="tcard-meta">
                            <span><i class="bi bi-geo-alt-fill" style="color:var(--g)"></i> @tour.DestinationName</span>
                            <span><i class="bi bi-clock"></i> @tour.DurationDays days</span>
                            <span><i class="bi bi-check-circle" style="color:var(--g)"></i> Free Cancellation</span>
                        </div>
                    </div>
                    <div class="tcard-footer">
                        <div>
                            <div class="tcard-price-label">from</div>
                            <div class="tcard-price">@tour.PricePerPerson.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("de-DE"))</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div style="text-align:center;padding:60px 20px;color:var(--gray)">
            <div style="font-size:3rem;margin-bottom:12px">🗺️</div>
            <p>No tours available from this operator yet.</p>
        </div>
    }
</div>