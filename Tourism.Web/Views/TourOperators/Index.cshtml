@model IEnumerable<Tourism.Web.Models.ViewModels.TourOperatorViewModel>
@{
    ViewData["Title"] = "Туроператори";
}

<style>
    .operator-card {
        background: #fff;
        border: 1px solid var(--viator-border);
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.2s, transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .operator-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            transform: translateY(-3px);
        }

    .operator-card-header {
        background: var(--viator-green-light);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .operator-logo {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--viator-green);
    }

    .operator-logo-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--viator-green);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .operator-card-body {
        padding: 1.25rem;
        flex: 1;
    }

    .operator-card-footer {
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--viator-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .operator-tour-count {
        color: var(--viator-green);
        font-weight: 700;
        font-size: 0.95rem;
    }

    .operator-contact {
        font-size: 0.875rem;
        color: var(--viator-gray);
        margin-bottom: 0.4rem;
    }
</style>

<div class="container my-4">
    <h1 class="mb-4">Нашите туроператори</h1>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var op in Model)
        {
            <div class="col">
                <div class="operator-card">
                    <div class="operator-card-header">
                        @if (!string.IsNullOrEmpty(op.LogoUrl))
                        {
                            <img src="@op.LogoUrl" class="operator-logo" alt="@op.Name" />
                        }
                        else
                        {
                            <div class="operator-logo-placeholder">
                                <i class="bi bi-building"></i>
                            </div>
                        }
                        <div>
                            <h5 class="mb-0 fw-bold">@op.Name</h5>
                        </div>
                    </div>
                    <div class="operator-card-body">
                        <p class="text-muted mb-3" style="font-size:0.9rem">
                            @(op.Description.Length > 100 ? op.Description.Substring(0, 100) + "…" : op.Description)
                        </p>
                        <p class="operator-contact"><i class="bi bi-envelope me-2" style="color:var(--viator-green)"></i>@op.Email</p>
                        <p class="operator-contact mb-0"><i class="bi bi-telephone me-2" style="color:var(--viator-green)"></i>@op.PhoneNumber</p>
                    </div>
                    <div class="operator-card-footer">
                        <span class="operator-tour-count">
                            <i class="bi bi-compass me-1"></i>@op.TourCount маршрута
                        </span>
                        <a asp-action="Details" asp-route-id="@op.Id" class="btn-viator">Виж маршрути</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
