@model Tourism.Web.Models.ViewModels.TourViewModel
@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div style="background:var(--viator-light);border-bottom:1px solid var(--viator-border)">
    <div class="container">
        <ul class="breadcrumb-viator">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Tours" asp-action="Index">Tours</a></li>
            <li><a asp-controller="Tours" asp-action="Index" asp-route-search="@Model.DestinationName">@Model.DestinationName</a></li>
            <li class="active">@Model.Title</li>
        </ul>
    </div>
</div>

@{
    var tourImages = ViewBag.TourImages as List<Tourism.Data.Models.Entities.TourImage>;
    var allImages = new List<string>();
    if (tourImages != null && tourImages.Any())
        allImages = tourImages.Select(i => i.ImageUrl).ToList();
    else if (!string.IsNullOrEmpty(Model.ImageUrl))
        allImages.Add(Model.ImageUrl);
    var mainImage = allImages.FirstOrDefault() ?? "";
}

@if (allImages.Any())
{
    <div class="gallery-wrap">
        <div class="gallery-main" id="galleryMain">
            <img src="@mainImage" alt="@Model.Title" id="galleryMainImg"
                 onerror="this.style.background='#E6F7F1'" />
            @if (allImages.Count > 1)
            {
                <button class="gallery-arrow gallery-prev" onclick="galleryNav(-1)">&#8249;</button>
                <button class="gallery-arrow gallery-next" onclick="galleryNav(1)">&#8250;</button>
                <div class="gallery-counter"><span id="galleryCurrent">1</span> / @allImages.Count</div>
            }
        </div>
    </div>
}

<div class="container vt-detail-layout">

    <article class="vt-detail-main">
        <h1 class="vt-detail-title">@Model.Title</h1>

        <div class="vt-detail-meta">
            <span class="vt-meta-pill"><i class="bi bi-geo-alt-fill"></i> @Model.DestinationName</span>
            <span class="vt-meta-pill"><i class="bi bi-building"></i> @Model.TourOperatorName</span>
            <span class="vt-meta-pill"><i class="bi bi-clock"></i> @Model.DurationDays days</span>
            <span class="vt-meta-pill"><i class="bi bi-people"></i> up to @Model.MaxParticipants participants</span>
            @if (Model.HasDiscount)
            {
                <span class="vt-meta-pill" style="background:#FEE2E2;border-color:#FECACA;color:#DC2626">
                    <i class="bi bi-tag-fill"></i> @Model.DiscountPercent.ToString("0")% OFF
                </span>
            }
        </div>

        @if (Model.ReviewCount > 0)
        {
            <div class="vt-rating-row">
                <div class="vt-rating-stars">@(new string('★', (int)Math.Round(Model.AverageRating)))</div>
                <div class="vt-rating-score">@Model.AverageRating.ToString("0.0")</div>
                <div class="vt-rating-label">@Model.ReviewCount reviews</div>
                <div class="vt-rating-bar-wrap">
                    <div class="vt-rating-bar" style="width:@((Model.AverageRating / 5.0 * 100).ToString("0"))%"></div>
                </div>
            </div>
        }

        <div class="vt-detail-divider"></div>

        <h2 class="vt-detail-section-title">About this tour</h2>
        <p class="vt-detail-desc">@Model.Description</p>

        <div class="vt-detail-divider"></div>

        <!-- Wikipedia Destination Guide -->
        <h2 class="vt-detail-section-title">
            <i class="bi bi-globe2" style="color:var(--viator-green)"></i>
            About @Model.DestinationName
        </h2>
        <div id="wiki-section">
            <div id="wiki-loading" style="display:flex;align-items:center;gap:8px;color:var(--viator-gray);font-size:.875rem;">
                <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                Loading destination info...
            </div>
            <div id="wiki-content" style="display:none;">
                <div style="background:var(--viator-light);border:1px solid var(--viator-border);border-radius:var(--radius);padding:16px 20px;">
                    <div style="display:flex;gap:14px;align-items:flex-start;">
                        <img id="wiki-thumb" src="" alt="" style="width:100px;height:80px;object-fit:cover;border-radius:8px;flex-shrink:0;display:none;" />
                        <div>
                            <p id="wiki-extract" style="font-size:.875rem;color:#374151;line-height:1.7;margin:0 0 8px;"></p>
                            <a id="wiki-link" href="#" target="_blank" rel="noopener"
                               style="font-size:.8rem;font-weight:600;color:var(--viator-green);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                <i class="bi bi-box-arrow-up-right"></i> Read more on Wikipedia
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div id="wiki-error" style="display:none;font-size:.875rem;color:var(--viator-gray);">
                Destination information not available.
            </div>
        </div>
        <div class="vt-detail-divider"></div>

        <!-- Weather Widget -->
        <h2 class="vt-detail-section-title">
            <i class="bi bi-cloud-sun" style="color:var(--viator-green)"></i>
            Current Weather in @Model.DestinationName
        </h2>
        <div id="weather-section">
            <div id="weather-loading" style="display:flex;align-items:center;gap:8px;color:var(--viator-gray);font-size:.875rem;">
                <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                Loading weather...
            </div>
            <div id="weather-content" style="display:none;">
                <div style="background:linear-gradient(135deg,#E6F7F1 0%,#EFF6FF 100%);border:1px solid var(--viator-border);border-radius:var(--radius);padding:16px 20px;">
                    <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <img id="weather-icon" src="" alt="" style="width:52px;height:52px;" />
                            <div>
                                <div id="weather-temp" style="font-size:2rem;font-weight:800;color:var(--viator-dark);line-height:1;"></div>
                                <div id="weather-desc" style="font-size:.82rem;color:var(--viator-gray);text-transform:capitalize;margin-top:2px;"></div>
                            </div>
                        </div>
                        <div style="display:flex;gap:20px;flex-wrap:wrap;">
                            <div style="text-align:center;">
                                <div style="font-size:.72rem;color:var(--viator-gray);text-transform:uppercase;letter-spacing:.04em;">Feels like</div>
                                <div id="weather-feels" style="font-size:.95rem;font-weight:600;"></div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:.72rem;color:var(--viator-gray);text-transform:uppercase;letter-spacing:.04em;">Humidity</div>
                                <div id="weather-humidity" style="font-size:.95rem;font-weight:600;"></div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:.72rem;color:var(--viator-gray);text-transform:uppercase;letter-spacing:.04em;">Wind</div>
                                <div id="weather-wind" style="font-size:.95rem;font-weight:600;"></div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:.72rem;color:var(--viator-gray);text-transform:uppercase;letter-spacing:.04em;">Visibility</div>
                                <div id="weather-visibility" style="font-size:.95rem;font-weight:600;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="weather-error" style="display:none;font-size:.875rem;color:var(--viator-gray);">
                Weather information not available.
            </div>
        </div>

        <div class="vt-detail-divider"></div>

        <h2 class="vt-detail-section-title">Details</h2>
        <div class="vt-info-grid">
            <div class="vt-info-item">
                <i class="bi bi-calendar-check"></i>
                <div>
                    <div class="vt-info-label">START DATE</div>
                    <div class="vt-info-value">@Model.StartDate.ToString("dd MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                </div>
            </div>
            <div class="vt-info-item">
                <i class="bi bi-calendar-x"></i>
                <div>
                    <div class="vt-info-label">END DATE</div>
                    <div class="vt-info-value">@Model.EndDate.ToString("dd MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                </div>
            </div>
            <div class="vt-info-item">
                <i class="bi bi-clock-history"></i>
                <div>
                    <div class="vt-info-label">DURATION</div>
                    <div class="vt-info-value">@Model.DurationDays days</div>
                </div>
            </div>
            <div class="vt-info-item">
                <i class="bi bi-people-fill"></i>
                <div>
                    <div class="vt-info-label">MAX PARTICIPANTS</div>
                    <div class="vt-info-value">@Model.MaxParticipants people</div>
                </div>
            </div>
        </div>

        <div class="vt-detail-divider"></div>

        <!-- What's Included / Not Included -->
        <h2 class="vt-detail-section-title"><i class="bi bi-list-check" style="color:var(--viator-green)"></i> What's included</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:8px;">
            <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:var(--radius);padding:16px 20px;">
                <div style="font-weight:700;font-size:.88rem;color:#166534;margin-bottom:12px;display:flex;align-items:center;gap:6px;">
                    <i class="bi bi-check-circle-fill" style="color:#16A34A"></i> Included
                </div>
                <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#166534">
                        <i class="bi bi-check-lg" style="color:#16A34A;flex-shrink:0;margin-top:1px"></i>
                        Professional tour guide (English)
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#166534">
                        <i class="bi bi-check-lg" style="color:#16A34A;flex-shrink:0;margin-top:1px"></i>
                        All entrance fees and tickets
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#166534">
                        <i class="bi bi-check-lg" style="color:#16A34A;flex-shrink:0;margin-top:1px"></i>
                        Hotel pickup and drop-off
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#166534">
                        <i class="bi bi-check-lg" style="color:#16A34A;flex-shrink:0;margin-top:1px"></i>
                        Air-conditioned transport
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#166534">
                        <i class="bi bi-check-lg" style="color:#16A34A;flex-shrink:0;margin-top:1px"></i>
                        Bottled water throughout the tour
                    </li>
                </ul>
            </div>
            <div style="background:#FFF7F7;border:1px solid #FECACA;border-radius:var(--radius);padding:16px 20px;">
                <div style="font-weight:700;font-size:.88rem;color:#991B1B;margin-bottom:12px;display:flex;align-items:center;gap:6px;">
                    <i class="bi bi-x-circle-fill" style="color:#DC2626"></i> Not included
                </div>
                <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#991B1B">
                        <i class="bi bi-x-lg" style="color:#DC2626;flex-shrink:0;margin-top:1px"></i>
                        Meals and beverages (unless noted)
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#991B1B">
                        <i class="bi bi-x-lg" style="color:#DC2626;flex-shrink:0;margin-top:1px"></i>
                        Personal travel insurance
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#991B1B">
                        <i class="bi bi-x-lg" style="color:#DC2626;flex-shrink:0;margin-top:1px"></i>
                        Optional activities and gratuities
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:.85rem;color:#991B1B">
                        <i class="bi bi-x-lg" style="color:#DC2626;flex-shrink:0;margin-top:1px"></i>
                        International flights
                    </li>
                </ul>
            </div>
        </div>

        <div class="vt-detail-divider"></div>

        <!-- Cancellation Policy -->
        <h2 class="vt-detail-section-title"><i class="bi bi-shield-check" style="color:var(--viator-green)"></i> Cancellation Policy</h2>
        <div style="background:var(--viator-green-light);border:1px solid #B2E5D4;border-radius:var(--radius);padding:16px 20px;margin-bottom:8px;">
            <div style="display:flex;align-items:flex-start;gap:12px;">
                <i class="bi bi-check-circle-fill" style="color:var(--viator-green);font-size:1.3rem;flex-shrink:0;margin-top:2px;"></i>
                <div>
                    <div style="font-weight:700;font-size:.92rem;color:var(--viator-dark);margin-bottom:4px;">Free cancellation</div>
                    <p style="font-size:.84rem;color:var(--viator-gray);margin:0;">
                        Cancel up to <strong>24 hours before</strong> the tour start date for a full refund. Cancellations made less than 24 hours in advance are non-refundable.
                    </p>
                </div>
            </div>
        </div>

        <div class="vt-detail-divider"></div>

        <!-- Share -->
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
            <span style="font-size:.82rem;color:var(--viator-gray);font-weight:600;margin-right:4px;">Share:</span>
            <button onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.innerHTML='<i class=\'bi bi-check-lg\'></i> Copied!';setTimeout(()=>{this.innerHTML='<i class=\'bi bi-link-45deg\'></i> Copy link'},2000)})"
                    style="background:var(--viator-light);border:1px solid var(--viator-border);padding:6px 14px;border-radius:50px;font-size:.8rem;font-weight:600;cursor:pointer;color:var(--viator-dark);display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-link-45deg"></i> Copy link
            </button>
            <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
               target="_blank" rel="noopener"
               style="background:#1877F2;color:#fff;padding:6px 14px;border-radius:50px;font-size:.8rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-facebook"></i> Facebook
            </a>
            <a href="https://twitter.com/intent/tweet?text=@Uri.EscapeDataString(Model.Title)&url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
               target="_blank" rel="noopener"
               style="background:#000;color:#fff;padding:6px 14px;border-radius:50px;font-size:.8rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-twitter-x"></i> X
            </a>
        </div>

        <h2 class="vt-detail-section-title">
            Reviews
            @if (Model.ReviewCount > 0)
            {
                <span class="vt-review-badge">@Model.ReviewCount</span>
            }
        </h2>

        @if (ViewBag.Reviews != null && ((IEnumerable<Tourism.Web.Models.ViewModels.ReviewViewModel>)ViewBag.Reviews).Any())
        {
            <div style="background:#fff;border:1px solid var(--viator-border);border-radius:var(--radius);padding:16px 20px;margin-bottom:20px;">
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;">
                    <div style="text-align:center;min-width:70px;">
                        <div style="font-size:2.2rem;font-weight:800;color:var(--viator-dark);line-height:1;">@Model.AverageRating.ToString("0.0")</div>
                        <div style="color:#F59E0B;font-size:.9rem;margin:2px 0;">@(new string('★', (int)Math.Round(Model.AverageRating)))</div>
                        <div style="font-size:.75rem;color:var(--viator-gray);">@Model.ReviewCount reviews</div>
                    </div>
                    <div style="flex:1;">
                        @foreach (var item in (IEnumerable<dynamic>)ViewBag.RatingBreakdown)
                        {
                            int star = (int)item.Star;
                            int count = (int)item.Count;
                            int pct = Model.ReviewCount > 0 ? (int)Math.Round(count * 100.0 / Model.ReviewCount) : 0;
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                <span style="font-size:.78rem;font-weight:600;color:var(--viator-dark);min-width:14px;text-align:right;">@star</span>
                                <i class="bi bi-star-fill" style="color:#F59E0B;font-size:.7rem;"></i>
                                <div style="flex:1;height:8px;background:var(--viator-border);border-radius:99px;overflow:hidden;">
                                    <div style="height:100%;width:@(pct)%;background:#F59E0B;border-radius:99px;"></div>
                                </div>
                                <span style="font-size:.75rem;color:var(--viator-gray);min-width:22px;">@count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="vt-reviews-list">
                @foreach (var review in (IEnumerable<Tourism.Web.Models.ViewModels.ReviewViewModel>)ViewBag.Reviews)
                {
                    <div class="vt-review-card">
                        <div class="vt-review-header">
                            <div class="vt-reviewer-avatar">@review.UserName.Substring(0, 1).ToUpper()</div>
                            <div>
                                <div class="vt-reviewer-name">@review.UserName</div>
                                <div class="vt-review-date">@review.CreatedAt.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</div>
                            </div>
                            <div class="vt-review-stars ms-auto">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= review.Rating ? "star-filled" : "star-empty")">★</span>
                                }
                            </div>
                        </div>
                        <p class="vt-review-text">@review.Comment</p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="vt-no-reviews">
                <div style="font-size:2.5rem;margin-bottom:12px">💬</div>
                <p>No reviews yet. Be the first!</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Reviews" asp-action="Create" asp-route-tourId="@Model.Id"
                       class="btn-viator-outline" style="margin-top:8px">Write a review</a>
                }
            </div>
        }

        <div class="vt-detail-divider"></div>

        <h2 class="vt-detail-section-title"><i class="bi bi-map" style="color:var(--viator-green)"></i> Location</h2>
        <div id="tour-map" style="width:100%;height:340px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--viator-border);"></div>
        <p style="font-size:0.8rem;color:var(--viator-gray);margin-top:8px">
            <i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @Model.DestinationName
        </p>

        <div class="vt-detail-divider"></div>

        @if (ViewBag.Recommendations != null && ((IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>)ViewBag.Recommendations).Any())
        {
            <h2 class="vt-detail-section-title">You might also like</h2>
            <div class="row g-3">
                @foreach (var rec in (IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>)ViewBag.Recommendations)
                {
                    <div class="col-12">
                        <a asp-action="Details" asp-route-id="@rec.Id" class="vt-rec-card">
                            @if (!string.IsNullOrEmpty(rec.ImageUrl))
                            {
                                <img src="@rec.ImageUrl" class="vt-rec-img" alt="@rec.Title" />
                            }
                            else
                            {
                                <div class="vt-rec-img" style="background:var(--viator-green-light);display:flex;align-items:center;justify-content:center;color:var(--viator-green);font-size:1.5rem">
                                    <i class="bi bi-map"></i>
                                </div>
                            }
                            <div class="vt-rec-body">
                                <div style="font-size:0.75rem;color:var(--viator-gray)">
                                    <i class="bi bi-geo-alt-fill" style="color:var(--viator-green)"></i> @rec.DestinationName &middot; @rec.DurationDays days
                                </div>
                                <div class="vt-rec-title">@rec.Title</div>
                                @if (rec.ReviewCount > 0)
                                {
                                    <div style="font-size:0.78rem;color:#F59E0B">★ @rec.AverageRating.ToString("0.0") <span style="color:var(--viator-gray)">(@rec.ReviewCount)</span></div>
                                }
                            </div>
                            <div class="vt-rec-price">
                                @if (rec.HasDiscount)
                                {
                                    <span style="text-decoration:line-through;color:#9CA3AF;font-size:.75rem;display:block">@rec.PricePerPerson.ToString("0") €</span>
                                    <span style="color:#DC2626">@rec.DiscountedPrice.ToString("0") €</span>
                                }
                                else
                                {
                                    @rec.PricePerPerson.ToString("0")
                                    <text> €</text>
                                }
                            </div>
                        </a>
                    </div>
                }
            </div>

            <div style="text-align:center;margin-top:20px;">
                <a asp-controller="Tours" asp-action="Index"
                   asp-route-search="@Model.DestinationName"
                   style="display:inline-flex;align-items:center;gap:8px;background:var(--viator-green-light);color:var(--viator-green);border:1.5px solid #A7F3D0;border-radius:999px;padding:10px 22px;font-size:.875rem;font-weight:600;text-decoration:none;">
                    <i class="bi bi-compass"></i>
                    Explore more tours in @Model.DestinationName
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        }
    </article>

    <!-- BOOKING SIDEBAR -->
    <aside class="vt-booking-card">
        <div class="vt-booking-price">
            @if (Model.HasDiscount)
            {
                <div style="margin-bottom:4px">
                    <span style="text-decoration:line-through;color:#9CA3AF;font-size:1rem">@Model.PricePerPerson.ToString("0.00") €</span>
                    <span style="background:#FEE2E2;color:#DC2626;border-radius:6px;padding:2px 8px;font-size:.8rem;font-weight:700;margin-left:6px">-@Model.DiscountPercent.ToString("0")%</span>
                </div>
                <span class="vt-price-big" style="color:#DC2626">@Model.DiscountedPrice.ToString("0.00") €</span>
                <span class="vt-price-per">per person</span>
            }
            else
            {
                <span class="vt-price-big">@Model.PricePerPerson.ToString("0.00") €</span>
                <span class="vt-price-per">per person</span>
            }
        </div>

        @if (Model.ReviewCount > 0)
        {
            <div class="vt-booking-rating">
                <span style="color:#F59E0B">★ @Model.AverageRating.ToString("0.0")</span>
                <span style="color:var(--viator-gray);font-size:0.82rem">(@Model.ReviewCount reviews)</span>
            </div>
        }

        <div class="vt-booking-dates">
            <div class="vt-booking-date-row">
                <i class="bi bi-calendar2-check" style="color:var(--viator-green)"></i>
                <span>@Model.StartDate.ToString("dd.MM.yyyy") → @Model.EndDate.ToString("dd.MM.yyyy")</span>
            </div>
            <div class="vt-booking-date-row">
                <i class="bi bi-clock" style="color:var(--viator-green)"></i>
                <span>@Model.DurationDays days</span>
            </div>
            <div class="vt-booking-date-row">
                <i class="bi bi-people" style="color:var(--viator-green)"></i>
                <span>up to @Model.MaxParticipants participants</span>
            </div>
        </div>

        @{
            int bookedSpots = ViewBag.BookedSpots ?? 0;
            int availableSpots = Model.MaxParticipants - bookedSpots;
            bool isFull = availableSpots <= 0;
            bool isLow = availableSpots > 0 && availableSpots <= 5;
        }
        @if (isFull)
        {
            <div class="vt-avail-badge vt-avail-full">
                <i class="bi bi-x-circle-fill"></i> Fully booked
            </div>
        }
        else if (isLow)
        {
            <div class="vt-avail-badge vt-avail-low">
                <i class="bi bi-fire"></i> Only @availableSpots spots left!
            </div>
        }
        else
        {
            <div class="vt-avail-badge vt-avail-ok">
                <i class="bi bi-check-circle-fill"></i> @availableSpots spots available
            </div>
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (!User.IsInRole("Operator") && !User.IsInRole("Admin"))
            {
                <a asp-controller="Bookings" asp-action="Create" asp-route-tourId="@Model.Id"
                   class="btn-viator vt-book-btn">Book Now</a>

                @if (ViewBag.IsFavorite == true)
                {
                    <form asp-controller="Favorites" asp-action="Remove" asp-route-id="@Model.Id" asp-route-returnUrl="@Context.Request.Path" method="post" style="margin-top:10px">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="vt-fav-btn vt-fav-active">
                            <i class="bi bi-heart-fill"></i> Remove from saved
                        </button>
                    </form>
                }
                else
                {
                    <form asp-controller="Favorites" asp-action="Add" asp-route-id="@Model.Id" method="post" style="margin-top:10px">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="vt-fav-btn">
                            <i class="bi bi-heart"></i> Save tour
                        </button>
                    </form>
                }

                @if (ViewBag.HasBooking == true)
                {
                    <a asp-controller="Reviews" asp-action="Create" asp-route-tourId="@Model.Id"
                       class="vt-review-btn">
                        <i class="bi bi-pencil-square"></i> Write a review
                    </a>
                }
                else
                {
                    <div style="text-align:center;font-size:0.78rem;color:var(--viator-gray);margin-top:10px;padding:8px;background:var(--viator-light);border-radius:8px">
                        <i class="bi bi-lock"></i> Book this tour to write a review
                    </div>
                }
            }
        }
        else
        {
            <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)"
               class="btn-viator vt-book-btn">
                Book Now
            </a>
            <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)"
               class="vt-fav-btn" style="margin-top:10px;display:flex;align-items:center;justify-content:center;gap:8px;">
                <i class="bi bi-heart"></i> Save tour
            </a>
            <div style="text-align:center;font-size:0.78rem;color:var(--viator-gray);margin-top:10px;padding:8px;background:var(--viator-light);border-radius:8px">
                <i class="bi bi-person"></i>
                <a href="/Identity/Account/Login" style="color:var(--viator-green);text-decoration:none;">Sign in</a>
                to book or save this tour
            </div>
        }

        <div class="vt-booking-guarantee">
            <i class="bi bi-shield-check"></i>
            <span>Secure booking. 24/7 support.</span>
        </div>
    </aside>

</div>

