@model Tourism.Web.Models.ViewModels.TourViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Начало</a></li>
            <li class="breadcrumb-item"><a asp-controller="Tours" asp-action="Index">Маршрути</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Main Info -->
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-4" alt="@Model.Title">
            }
            <h1>@Model.Title</h1>
            <p class="text-muted">
                <i class="bi bi-geo-alt"></i> @Model.DestinationName &nbsp;|&nbsp;
                <i class="bi bi-person"></i> @Model.TourOperatorName
            </p>
            @if (Model.ReviewCount > 0)
            {
                <p class="text-warning fs-5">★ @Model.AverageRating.ToString("0.0") <small class="text-muted">(@Model.ReviewCount ревюта)</small></p>
            }
            <p>@Model.Description</p>
        </div>

        <!-- Booking Sidebar -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h4 class="text-primary">@Model.PricePerPerson.ToString("C") <small class="text-muted fs-6">/ човек</small></h4>
                <ul class="list-unstyled mt-3">
                    <li><i class="bi bi-calendar-check"></i> <strong>Старт:</strong> @Model.StartDate.ToString("dd.MM.yyyy")</li>
                    <li><i class="bi bi-calendar-x"></i> <strong>Край:</strong> @Model.EndDate.ToString("dd.MM.yyyy")</li>
                    <li><i class="bi bi-clock"></i> <strong>Продължителност:</strong> @Model.DurationDays дни</li>
                    <li><i class="bi bi-people"></i> <strong>Макс. участници:</strong> @Model.MaxParticipants</li>
                </ul>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Favorites" asp-action="Add" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100 mt-2">♥ Добави в любими</button>
                    </form>
                    <a asp-controller="Bookings" asp-action="Create" asp-route-tourId="@Model.Id"
                       class="btn btn-primary w-100 mt-2">Резервирай сега</a>
                    <a asp-controller="Reviews" asp-action="Create" asp-route-tourId="@Model.Id"
                       class="btn btn-outline-secondary w-100 mt-2">Напиши ревю</a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary w-100 mt-2">
                        Влез за да резервираш
                    </a>
                }
            </div>
        </div>
    </div>
</div>