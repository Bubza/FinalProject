@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@{
    ViewData["Title"] = "Tour Catalog";
    var qSearch = Context.Request.Query["search"].ToString();
    var qMinPrice = Context.Request.Query["minPrice"].ToString();
    var qMaxPrice = Context.Request.Query["maxPrice"].ToString();
    var qDuration = Context.Request.Query["duration"].ToString();
    var qRating = Context.Request.Query["minRating"].ToString();
    var qSort = Context.Request.Query["sortBy"].ToString();
    var qStartDate = Context.Request.Query["startDate"].ToString();
    var qEndDate = Context.Request.Query["endDate"].ToString();
    var qPeople = Context.Request.Query["people"].ToString();
    int.TryParse(qPeople, out int qPeopleInt);
}

<style>
    :root {
        --g: #00AA6C;
        --gd: #008A57;
        --gl: #E6F7F1;
        --dark: #1A1A1A;
        --gray: #6B7280;
        --border: #E5E7EB;
        --r: 12px;
    }

    .catalog-header {
        margin-bottom: 1.25rem;
    }

    .filter-pills {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 1rem;
    }

    .pill-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border: 1.5px solid var(--border);
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 500;
        background: #fff;
        color: var(--dark);
        cursor: pointer;
        white-space: nowrap;
        transition: border-color .15s, background .15s;
        text-decoration: none;
    }

        .pill-btn:hover, .pill-btn.active {
            border-color: var(--dark);
            background: #fff;
            color: var(--dark);
        }

        .pill-btn.pill-filter {
            font-weight: 600;
        }

    .pill-search {
        flex: 1;
        min-width: 220px;
        max-width: 420px;
        position: relative;
    }

        .pill-search input {
            width: 100%;
            padding: 9px 16px 9px 40px;
            border: 1.5px solid var(--border);
            border-radius: 50px;
            font-size: 0.875rem;
            outline: none;
            transition: border-color .15s;
            font-family: 'Poppins',sans-serif;
        }

            .pill-search input:focus {
                border-color: var(--dark);
            }

        .pill-search .si {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray);
        }

    .results-meta {
        font-size: 0.875rem;
        color: var(--gray);
        margin-bottom: 1rem;
    }

        .results-meta strong {
            color: var(--dark);
        }

    .tour-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    @@media(max-width:1100px) {
        .tour-grid {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:768px) {
        .tour-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:480px) {
        .tour-grid {
            grid-template-columns: 1fr;
        }
    }

    .tcard {
        border-radius: var(--r);
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--border);
        transition: box-shadow .2s, transform .2s;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .tcard:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,.11);
            transform: translateY(-2px);
        }

    .tcard-img-wrap {
        position: relative;
        overflow: hidden;
    }

    .tcard-img {
        width: 100%;
        height: 185px;
        object-fit: cover;
        display: block;
        transition: transform .3s;
    }

    .tcard:hover .tcard-img {
        transform: scale(1.04);
    }

    .tcard-img-placeholder {
        width: 100%;
        height: 185px;
        background: linear-gradient(135deg,#e0f2eb,#c5e8d8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--g);
        font-size: 2.5rem;
    }

    .tcard-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #fff;
        color: var(--dark);
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 50px;
        box-shadow: 0 2px 6px rgba(0,0,0,.15);
    }

    .tcard-heart {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: rgba(255,255,255,.9);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: none;
        box-shadow: 0 2px 6px rgba(0,0,0,.15);
        transition: transform .15s;
    }

        .tcard-heart:hover {
            transform: scale(1.1);
        }

        .tcard-heart i {
            font-size: 1rem;
            color: #6B7280;
        }

    .tcard-body {
        padding: 12px 14px 8px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .tcard-rating {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.82rem;
        margin-bottom: 5px;
    }

        .tcard-rating .star {
            color: #F59E0B;
            font-size: 0.85rem;
        }

        .tcard-rating .rval {
            font-weight: 700;
        }

        .tcard-rating .rcnt {
            color: var(--gray);
        }

    .tcard-title {
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 6px;
        color: var(--dark);
        flex: 1;
    }

    .tcard-meta {
        font-size: 0.8rem;
        color: var(--gray);
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-bottom: 8px;
    }

        .tcard-meta span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

    .tcard-footer {
        padding: 10px 14px 12px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tcard-price-label {
        font-size: 0.72rem;
        color: var(--gray);
    }

    .tcard-price {
        font-size: 1rem;
        font-weight: 700;
        color: var(--dark);
    }

    .btn-details {
        background: var(--g);
        color: #fff !important;
        border: none;
        padding: 7px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.8rem;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
    }

        .btn-details:hover {
            background: var(--gd);
        }

    .filter-drawer {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        display: none;
    }

        .filter-drawer.open {
            display: block;
        }

    .filter-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: flex-end;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
        min-width: 130px;
    }

        .fg label {
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--gray);
            text-transform: uppercase;
        }

        .fg input, .fg select {
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 0.875rem;
            font-family: 'Poppins',sans-serif;
            outline: none;
            transition: border-color .15s;
        }

            .fg input:focus, .fg select:focus {
                border-color: var(--g);
            }

    .btn-apply {
        background: var(--g);
        color: #fff;
        border: none;
        padding: 9px 22px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
    }

        .btn-apply:hover {
            background: var(--gd);
        }

    .btn-reset {
        background: #fff;
        color: var(--dark);
        border: 1.5px solid var(--border);
        padding: 9px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-block;
    }

        .btn-reset:hover {
            border-color: var(--gray);
            color: var(--dark);
        }
</style>

<div class="container my-4">
    <h1 class="mb-3" style="font-size:1.6rem;font-weight:700">Tour Catalog</h1>

    <form method="get" id="filterForm">
        <div class="filter-pills">
            <div class="pill-search">
                <i class="bi bi-search si"></i>
                <input type="text" id="searchInput" name="search" placeholder="Destination or tour..." value="@qSearch" autocomplete="off" />
            </div>
            <!-- Date pill -->
            <div style="position:relative">
                <button type="button" class="pill-btn @(!string.IsNullOrEmpty(qStartDate) ? "active" : "")" id="datePillBtn">
                    <i class="bi bi-calendar3"></i>
                    @if (!string.IsNullOrEmpty(qStartDate))
                    {
                        <span>@qStartDate@(!string.IsNullOrEmpty(qEndDate) ? " — " + qEndDate : "")</span>
                        <span onclick="clearDates(event)" style="margin-left:4px;font-size:1rem;line-height:1">×</span>
                    }
                    else
                    {
                        <span>When are you traveling?</span>
                    }
                </button>
                <input type="hidden" name="startDate" id="startDateInput" value="@qStartDate" />
                <input type="hidden" name="endDate" id="endDateInput" value="@qEndDate" />
                <input type="text" id="datePicker" style="position:absolute;opacity:0;pointer-events:none;width:1px;height:1px;top:100%;left:0" readonly />
            </div>
            <button type="button" class="pill-btn pill-filter" onclick="document.getElementById('filterDrawer').classList.toggle('open')">
                <i class="bi bi-sliders"></i> Filters
            </button>
            @if (qDuration == "1-3")
            {
                <span class="pill-btn active">1–3 days ×</span>
            }
            @if (qDuration == "4-7")
            {
                <span class="pill-btn active">4–7 days ×</span>
            }
            @if (qDuration == "8+")
            {
                <span class="pill-btn active">8+ days ×</span>
            }
            @if (!string.IsNullOrEmpty(qMinPrice) || !string.IsNullOrEmpty(qMaxPrice))
            {
                <span class="pill-btn active">Price ×</span>
            }
            @if (!string.IsNullOrEmpty(qRating))
            {
                <span class="pill-btn active">Rating @qRating+ ×</span>
            }
            <!-- People pill -->
            <div style="position:relative">
                <button type="button" class="pill-btn @(!string.IsNullOrEmpty(qPeople) && qPeopleInt > 0 ? "active" : "")" id="peoplePillBtn">
                    <i class="bi bi-person"></i>
                    <span id="peoplePillLabel">@(qPeopleInt > 0 ? qPeopleInt + " " + (qPeopleInt == 1 ? "person" : "people") : "Travelers")</span>
                </button>
                <input type="hidden" name="people" id="peopleInput" value="@qPeople" />
                <div id="peopleDropdown" style="display:none;position:absolute;top:calc(100% + 8px);left:0;background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.25rem 1.5rem;box-shadow:0 8px 32px rgba(0,0,0,.15);z-index:999;min-width:260px">
                    <p style="font-size:0.8rem;color:var(--gray);margin-bottom:1rem">You can select up to 15 travelers</p>
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
                        <span style="font-weight:500">Travelers</span>
                        <div style="display:flex;align-items:center;gap:12px">
                            <button type="button" onclick="changePeople(-1)" style="width:32px;height:32px;border-radius:50%;border:1.5px solid var(--g);background:#fff;color:var(--g);font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center">−</button>
                            <span id="peopleCount" style="font-weight:700;font-size:1.1rem;min-width:20px;text-align:center">@(qPeopleInt > 0 ? qPeopleInt : 1)</span>
                            <button type="button" onclick="changePeople(1)" style="width:32px;height:32px;border-radius:50%;border:1.5px solid var(--g);background:#fff;color:var(--g);font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center">+</button>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px">
                        <button type="button" onclick="resetPeople()" style="flex:1;padding:9px;border:1.5px solid var(--border);border-radius:8px;background:#fff;font-weight:600;font-size:0.875rem;cursor:pointer">Reset</button>
                        <button type="button" onclick="applyPeople()" style="flex:1;padding:9px;background:var(--g);color:#fff;border:none;border-radius:8px;font-weight:600;font-size:0.875rem;cursor:pointer">Apply</button>
                    </div>
                </div>
            </div>

            <div class="ms-auto d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(qSearch) || !string.IsNullOrEmpty(qDuration) || !string.IsNullOrEmpty(qMinPrice) || !string.IsNullOrEmpty(qRating) || !string.IsNullOrEmpty(qStartDate) || qPeopleInt > 0)
                {
                    <a asp-action="Index" style="font-size:0.85rem;font-weight:600;color:#DC2626;text-decoration:none;white-space:nowrap;padding:7px 12px;border:1.5px solid #FECACA;border-radius:50px;background:#FEF2F2">Clear all</a>
                }
                <select name="sortBy" onchange="this.form.submit()" style="border:1.5px solid var(--border);border-radius:50px;padding:7px 30px 7px 16px;font-size:0.85rem;font-family:'Poppins',sans-serif;outline:none;cursor:pointer;appearance:none;">
                    <option value="">Sort by</option>
                    @if (qSort == "price_asc")
                    {
                        <option value="price_asc" selected="selected">Price: Low to High</option>
                    }
                    else
                    {
                        <option value="price_asc">Price: Low to High</option>
                    }
                    @if (qSort == "price_desc")
                    {
                        <option value="price_desc" selected="selected">Price: High to Low</option>
                    }
                    else
                    {
                        <option value="price_desc">Price: High to Low</option>
                    }
                    @if (qSort == "rating")
                    {
                        <option value="rating" selected="selected">Highest rating</option>
                    }
                    else
                    {
                        <option value="rating">Highest rating</option>
                    }
                    @if (qSort == "duration")
                    {
                        <option value="duration" selected="selected">Duration</option>
                    }
                    else
                    {
                        <option value="duration">Duration</option>
                    }
                </select>
                <button type="submit" class="btn-details" style="padding:8px 20px">Search</button>
            </div>
        </div>

        <!-- collapsible filter drawer -->
        <div class="filter-drawer @(!string.IsNullOrEmpty(qDuration) || !string.IsNullOrEmpty(qMinPrice) || !string.IsNullOrEmpty(qMaxPrice) || !string.IsNullOrEmpty(qRating) ? "open" : "")" id="filterDrawer">
            <div class="filter-row">
                <div class="fg">
                    <label>Min. price (€)</label>
                    <input type="number" name="minPrice" placeholder="0" value="@qMinPrice" />
                </div>
                <div class="fg">
                    <label>Max. price (€)</label>
                    <input type="number" name="maxPrice" placeholder="10000" value="@qMaxPrice" />
                </div>
                <div class="fg">
                    <label>Duration</label>
                    <select name="duration">
                        <option value="">All</option>
                        @if (qDuration == "1-3")
                        {
                            <option value="1-3" selected>1–3 days</option>
                        }
                        else
                        {
                            <option value="1-3">1–3 days</option>
                        }
                        @if (qDuration == "4-7")
                        {
                            <option value="4-7" selected>4–7 days</option>
                        }
                        else
                        {
                            <option value="4-7">4–7 days</option>
                        }
                        @if (qDuration == "8+")
                        {
                            <option value="8+" selected>8+ days</option>
                        }
                        else
                        {
                            <option value="8+">8+ days</option>
                        }
                    </select>
                </div>
                <div class="fg">
                    <label>Min. rating</label>
                    <select name="minRating">
                        <option value="">All</option>
                        @if (qRating == "3")
                        {
                            <option value="3" selected>★★★ 3+</option>
                        }
                        else
                        {
                            <option value="3">★★★ 3+</option>
                        }
                        @if (qRating == "4")
                        {
                            <option value="4" selected>★★★★ 4+</option>
                        }
                        else
                        {
                            <option value="4">★★★★ 4+</option>
                        }
                        @if (qRating == "5")
                        {
                            <option value="5" selected>★★★★★ 5</option>
                        }
                        else
                        {
                            <option value="5">★★★★★ 5</option>
                        }
                    </select>
                </div>
                <div class="fg" style="flex:0;min-width:auto;flex-direction:row;gap:8px;align-self:flex-end">
                    <button type="submit" class="btn-apply">Apply</button>
                    <a asp-action="Index" class="btn-reset">Reset</a>
                </div>
            </div>
        </div>
    </form>

    <p class="results-meta">Found: <strong>@Model.Count()</strong> tours</p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No tours found. <a asp-action="Index">Show all</a></div>
    }
    else
    {
        <div class="tour-grid">
            @foreach (var tour in Model)
            {
                <div class="tcard">
                    <div class="tcard-img-wrap">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="tcard-img" alt="@tour.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="tcard-img-placeholder"><i class="bi bi-map"></i></div>
                        }
                        @if (tour.AverageRating >= 4.5 && tour.ReviewCount >= 3)
                        {
                            <span class="tcard-badge">⭐ Best Seller</span>
                        }
                        <form asp-controller="Favorites" asp-action="Add" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@tour.Id" />
                            <button type="submit" class="tcard-heart" title="Save to favorites">
                                <i class="bi bi-heart"></i>
                            </button>
                        </form>
                    </div>
                    <div class="tcard-body">
                        @if (tour.ReviewCount > 0)
                        {
                            <div class="tcard-rating">
                                <span class="star">★</span>
                                <span class="rval">@tour.AverageRating.ToString("0.0")</span>
                                <span class="rcnt">(@tour.ReviewCount)</span>
                            </div>
                        }
                        <div class="tcard-title">@tour.Title</div>
                        <div class="tcard-meta">
                            <span><i class="bi bi-geo-alt-fill" style="color:var(--g)"></i> @tour.DestinationName</span>
                            <span><i class="bi bi-clock"></i> @tour.DurationDays days</span>
                            <span><i class="bi bi-check-circle" style="color:var(--g)"></i> Free Cancellation</span>
                        </div>
                    </div>
                    <div class="tcard-footer">
                        <div>
                            <div class="tcard-price-label">from</div>
                            @if (tour.HasDiscount)
                            {
                                <div>
                                    <span style="text-decoration:line-through;color:#9CA3AF;font-size:.8rem">@tour.PricePerPerson.ToString("C")</span>
                                    <span class="tcard-price" style="color:#DC2626">@tour.DiscountedPrice.ToString("C")</span>
                                    <span style="background:#FEE2E2;color:#DC2626;border-radius:4px;padding:2px 6px;font-size:.72rem;font-weight:700">-@tour.DiscountPercent.ToString("0")%</span>
                                </div>
                            }
                            else
                            {
                                <div class="tcard-price">@tour.PricePerPerson.ToString("C")</div>
                            }
                        </div>
                        <a asp-action="Details" asp-route-id="@tour.Id" class="btn-details">View</a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .flatpickr-calendar {
            font-family: 'Poppins',sans-serif !important;
            border-radius: 16px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,.15) !important;
            border: none !important;
        }

        .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange {
            background: #00AA6C !important;
            border-color: #00AA6C !important;
        }

        .flatpickr-day.inRange {
            background: #E6F7F1 !important;
            border-color: #E6F7F1 !important;
            color: #00AA6C !important;
        }

        .flatpickr-day:hover {
            background: #E6F7F1 !important;
        }

        .flatpickr-day.today {
            border-color: #00AA6C !important;
        }

        .flatpickr-current-month {
            font-weight: 700 !important;
        }

        .flatpickr-weekday {
            color: #6B7280 !important;
            font-weight: 600 !important;
        }

        .flatpickr-months .flatpickr-month {
            background: #fff !important;
        }
        /* Autocomplete dropdown styling */
        .pac-container {
            border-radius: 12px;
            border: 1px solid #E5E7EB;
            box-shadow: 0 8px 24px rgba(0,0,0,.12);
            font-family: 'Poppins',sans-serif;
            margin-top: 4px;
        }

        .pac-item {
            padding: 8px 14px;
            font-size: .88rem;
            cursor: pointer;
        }

            .pac-item:hover {
                background: #E6F7F1;
            }

        .pac-item-query {
            color: #1A1A1A;
            font-weight: 600;
        }

        .pac-matched {
            color: #00AA6C;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        var fp = flatpickr("#datePicker", {
            mode: "range",
            minDate: "today",
            dateFormat: "Y-m-d",
            onChange: function(selectedDates) {
                var start = selectedDates[0] ? selectedDates[0].toISOString().split("T")[0] : "";
                var end   = selectedDates[1] ? selectedDates[1].toISOString().split("T")[0] : "";
                document.getElementById("startDateInput").value = start;
                document.getElementById("endDateInput").value   = end;
                var btn = document.getElementById("datePillBtn").querySelector("span");
                if (start) btn.textContent = start + (end ? " — " + end : "");
            },
            onClose: function() {
                if (document.getElementById("startDateInput").value) {
                    document.getElementById("filterForm").submit();
                }
            }
        });

        document.getElementById("datePillBtn").addEventListener("click", function(e) {
            if (e.target.tagName !== "SPAN" || e.target.textContent !== "×") fp.open();
        });

        var currentPeople = @(qPeopleInt > 0 ? qPeopleInt : 1);
        document.getElementById("peoplePillBtn").addEventListener("click", function(e) {
            e.stopPropagation();
            var d = document.getElementById("peopleDropdown");
            d.style.display = d.style.display === "none" ? "block" : "none";
        });
        document.getElementById("peopleDropdown").addEventListener("click", function(e) { e.stopPropagation(); });
        document.addEventListener("click", function() { document.getElementById("peopleDropdown").style.display = "none"; });

        function changePeople(delta) {
            currentPeople = Math.max(1, Math.min(15, currentPeople + delta));
            document.getElementById("peopleCount").textContent = currentPeople;
        }
        function applyPeople() {
            document.getElementById("peopleInput").value = currentPeople;
            document.getElementById("peoplePillLabel").textContent = currentPeople + " " + (currentPeople === 1 ? "person" : "people");
            document.getElementById("peopleDropdown").style.display = "none";
            document.getElementById("filterForm").submit();
        }
        function resetPeople() {
            currentPeople = 1;
            document.getElementById("peopleCount").textContent = "1";
            document.getElementById("peopleInput").value = "";
            document.getElementById("peopleDropdown").style.display = "none";
            document.getElementById("filterForm").submit();
        }
        function clearDates(e) {
            e.stopPropagation();
            document.getElementById("startDateInput").value = "";
            document.getElementById("endDateInput").value   = "";
            fp.clear();
            document.getElementById("filterForm").submit();
        }

        // Google Places Autocomplete (new API)
        async function initAutocomplete() {
            const { PlaceAutocompleteElement } = await google.maps.importLibrary("places");

            const input = document.getElementById("searchInput");
            const parent = input.parentElement;

            // Create the new autocomplete element
            const placeAuto = new PlaceAutocompleteElement({
                types: ["(cities)"]
            });

            // Style it to match our input
            placeAuto.style.cssText = `
                position: absolute;
                top: 0; left: 0; right: 0; bottom: 0;
                opacity: 0;
                pointer-events: auto;
                z-index: 10;
            `;

            // Use a simpler approach - just enhance the existing input
            // by listening to place_changed on a hidden autocomplete service
            const autocompleteService = new google.maps.places.AutocompleteService();
            const sessionToken = new google.maps.places.AutocompleteSessionToken();

            // Create suggestions dropdown
            const dropdown = document.createElement("div");
            dropdown.style.cssText = "position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1000;display:none;margin-top:4px;overflow:hidden;font-family:'Poppins',sans-serif";
            parent.style.position = "relative";
            parent.appendChild(dropdown);

            input.addEventListener("input", function() {
                const val = this.value.trim();
                if (val.length < 2) { dropdown.style.display = "none"; return; }

                autocompleteService.getPlacePredictions(
                    {
                        input: val,
                        types: ["(cities)"],
                        sessionToken,
                        locationBias: new google.maps.LatLngBounds(
                            new google.maps.LatLng(35.0, -10.0),  // SW Europe
                            new google.maps.LatLng(70.0, 40.0)    // NE Europe
                        )
                    },
                    function(predictions, status) {
                        if (status !== google.maps.places.PlacesServiceStatus.OK || !predictions) {
                            dropdown.style.display = "none"; return;
                        }
                        dropdown.innerHTML = "";
                        predictions.slice(0, 5).forEach(function(p) {
                            const item = document.createElement("div");
                            item.style.cssText = "padding:10px 16px;cursor:pointer;font-size:.88rem;color:#1A1A1A;border-bottom:1px solid #F3F4F6;display:flex;align-items:center;gap:10px";
                            item.innerHTML = `<i class="bi bi-geo-alt" style="color:#00AA6C"></i> ${p.description}`;
                            item.addEventListener("mousedown", function(e) {
                                e.preventDefault();
                                // Use only the city name (first part before comma)
                                const cityName = p.description.split(",")[0].trim();
                                input.value = cityName;
                                dropdown.style.display = "none";
                                document.getElementById("filterForm").submit();
                            });
                            item.addEventListener("mouseover", function() { this.style.background = "#E6F7F1"; });
                            item.addEventListener("mouseout", function() { this.style.background = ""; });
                            dropdown.appendChild(item);
                        });
                        dropdown.style.display = "block";
                    }
                );
            });

            input.addEventListener("blur", function() {
                setTimeout(function() { dropdown.style.display = "none"; }, 150);
            });

            input.addEventListener("keydown", function(e) {
                if (e.key === "Escape") dropdown.style.display = "none";
            });
        }
        window.initMaps = initAutocomplete;
    </script>
    <script async defer
            src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCGQ6q74bpBejjpvAt1VQpHxZ7rtynPEy8&libraries=places&callback=initMaps">
    </script>
}