@model IEnumerable<Tourism.Web.Models.ViewModels.TourViewModel>
@{
    ViewData["Title"] = "Каталог маршрути";
}

<div class="container my-4">
    <h1 class="mb-4">Каталог маршрути</h1>

    <!-- Filters -->
    <form method="get" class="row g-3 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" class="form-control" placeholder="Търси по дестинация или маршрут..."
                   value="@Context.Request.Query["search"]" />
        </div>
        <div class="col-md-3">
            <input type="number" name="maxPrice" class="form-control" placeholder="Макс. цена"
                   value="@Context.Request.Query["maxPrice"]" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Търси</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Изчисти</a>
        </div>
    </form>

    <!-- Tour Cards -->
    @if (!Model.Any())
    {
        <div class="alert alert-info">Няма намерени маршрути.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tour in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(tour.ImageUrl))
                        {
                            <img src="@tour.ImageUrl" class="card-img-top" alt="@tour.Title" style="height:200px;object-fit:cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@tour.Title</h5>
                            <p class="text-muted mb-1"><i class="bi bi-geo-alt"></i> @tour.DestinationName</p>
                            <p class="text-muted mb-2"><i class="bi bi-calendar"></i> @tour.DurationDays дни</p>
                            @if (tour.ReviewCount > 0)
                            {
                                <p class="text-warning mb-2">
                                    ★ @tour.AverageRating.ToString("0.0") <small class="text-muted">(@tour.ReviewCount ревюта)</small>
                                </p>
                            }
                            <p class="card-text">@tour.Description.Substring(0, Math.Min(80, tour.Description.Length))...</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <strong class="text-primary">@tour.PricePerPerson.ToString("C")</strong>
                            <a asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-primary btn-sm">Детайли</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
